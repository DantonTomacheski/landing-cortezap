---
---

<section class="relative py-24 sm:py-32">
  <!-- Subtle mesh gradient behind -->
  <div class="pointer-events-none absolute inset-0">
    <div class="absolute top-[20%] left-[30%] w-[40%] h-[40%] rounded-full bg-[radial-gradient(circle,rgba(120,80,200,0.04),transparent_70%)]"></div>
  </div>

  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="animate-on-scroll text-center">
      <h2 class="text-3xl font-semibold tracking-tight sm:text-4xl text-white">
        Painel para barbeiro e gestão completa
      </h2>
      <p class="mt-4 max-w-2xl mx-auto text-base text-text-secondary">
        Interface intuitiva com notificações em tempo real, agenda visual, clientes e controle financeiro completo.
      </p>
    </div>

    <!-- Browser frame -->
    <div class="animate-on-scroll mx-auto mt-16 max-w-5xl">
      <div class="overflow-hidden rounded-xl border border-white/[0.06] shadow-2xl shadow-black/50">
        <!-- Browser chrome -->
        <div class="flex items-center gap-2 bg-white/[0.03] px-4 py-3 border-b border-white/[0.06] shrink-0">
          <div class="flex gap-1.5">
            <div class="h-2.5 w-2.5 rounded-full bg-white/[0.1]"></div>
            <div class="h-2.5 w-2.5 rounded-full bg-white/[0.1]"></div>
            <div class="h-2.5 w-2.5 rounded-full bg-white/[0.1]"></div>
          </div>
          <div class="ml-4 flex-1 rounded-md bg-white/[0.03] px-3 py-1 border border-white/[0.06] flex justify-center items-center">
            <p class="text-[11px] font-mono text-text-muted flex items-center gap-1.5"><svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg> painel.cortezap.app.br</p>
          </div>
          <div class="w-12"></div>
        </div>

        <!-- App Layout -->
        <div class="flex h-[560px] bg-[#0c0c0e]">
          <!-- Sidebar -->
          <div class="hidden sm:flex w-52 flex-col border-r border-white/[0.06] bg-[#09090b] p-4">
             <div class="flex items-center gap-2 px-2 py-3 mb-3">
                <div class="h-7 w-7 rounded-lg bg-brand-500 flex items-center justify-center text-xs font-semibold text-white">C</div>
                <span class="font-semibold text-white text-sm">CorteZap</span>
             </div>

             <nav class="flex-1 space-y-0.5">
               <div class="flex items-center gap-2.5 rounded-lg bg-white/[0.06] px-3 py-2 text-sm text-white font-medium cursor-pointer">
                 <svg class="h-4 w-4 text-text-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"></path></svg>
                 Dashboard
               </div>
               <div class="flex items-center gap-2.5 rounded-lg px-3 py-2 text-sm text-text-secondary hover:bg-white/[0.03] hover:text-white transition-colors cursor-pointer">
                 <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                 Agenda
               </div>
               <div class="flex items-center gap-2.5 rounded-lg px-3 py-2 text-sm text-text-secondary hover:bg-white/[0.03] hover:text-white transition-colors cursor-pointer">
                 <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path></svg>
                 Clientes
               </div>
               <div class="flex items-center gap-2.5 rounded-lg px-3 py-2 text-sm text-text-secondary hover:bg-white/[0.03] hover:text-white transition-colors cursor-pointer">
                 <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                 Financeiro
               </div>
             </nav>
             <div class="pt-3 border-t border-white/[0.06]">
                <div class="flex items-center gap-2.5 rounded-lg px-3 py-2 text-sm text-text-secondary hover:bg-white/[0.03] hover:text-white cursor-pointer">
                  <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                  Ajustes
                </div>
             </div>
          </div>

          <!-- Main Content -->
          <div class="flex-1 flex flex-col p-5 sm:p-6 overflow-y-auto relative">
            <h1 class="text-lg font-semibold text-white mb-5">Dashboard</h1>

            <!-- Real-time Notification Toast -->
            <div id="demo-notification" class="absolute top-5 right-5 translate-x-full opacity-0 pointer-events-none transition-all duration-500 ease-[cubic-bezier(0.175,0.885,0.32,1.275)] flex items-center gap-3 rounded-lg border border-white/[0.08] bg-[#131316] p-3 shadow-2xl z-50">
              <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-brand-500/10 text-brand-400">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"></path></svg>
              </div>
              <div>
                <p class="text-xs font-medium text-white">Novo Agendamento</p>
                <p class="text-[11px] text-text-muted">Via WhatsApp Bot · Agora</p>
              </div>
            </div>

            <div class="grid gap-3 sm:grid-cols-4 mb-6">
              <div class="rounded-lg border border-white/[0.06] bg-white/[0.02] p-4" id="card-agendamentos">
                <p class="text-[11px] font-medium text-text-muted uppercase tracking-wider">Agendamentos</p>
                <p class="mt-1.5 text-2xl font-semibold text-white" id="stat-agendamentos">12</p>
                <p class="mt-1 text-[11px] text-emerald-400">+3 hoje</p>
              </div>
              <div class="rounded-lg border border-white/[0.06] bg-white/[0.02] p-4" id="card-faturamento">
                <p class="text-[11px] font-medium text-text-muted uppercase tracking-wider">Faturamento</p>
                <p class="mt-1.5 text-2xl font-semibold text-white" id="stat-faturamento"><span class="text-sm text-text-muted">R$</span> 540</p>
                <p class="mt-1 text-[11px] text-emerald-400">Via Pix</p>
              </div>
              <div class="rounded-lg border border-white/[0.06] bg-white/[0.02] p-4">
                <p class="text-[11px] font-medium text-text-muted uppercase tracking-wider">Pacotes</p>
                <p class="mt-1.5 text-2xl font-semibold text-white">4</p>
                <p class="mt-1 text-[11px] text-text-muted">Em andamento</p>
              </div>
              <div class="rounded-lg border border-white/[0.06] bg-white/[0.02] p-4">
                <p class="text-[11px] font-medium text-text-muted uppercase tracking-wider">Novos Clientes</p>
                <p class="mt-1.5 text-2xl font-semibold text-white">2</p>
                <p class="mt-1 text-[11px] text-text-muted">Via WhatsApp</p>
              </div>
            </div>

            <!-- Agenda rows -->
            <div class="rounded-lg border border-white/[0.06] bg-white/[0.02] p-4 flex-1 flex flex-col">
              <div class="mb-4 flex items-center justify-between">
                <div>
                   <p class="text-sm font-medium text-white">Agenda de Hoje</p>
                   <p class="text-[11px] text-text-muted mt-0.5">Sábado, 02 de Março</p>
                </div>
                <button class="rounded-lg bg-brand-500 px-3 py-1.5 text-[11px] font-medium text-white hover:bg-brand-600 transition-colors">Novo Horário</button>
              </div>
              <div class="space-y-1" id="agenda-rows-container">
                {[
                  { time: '09:45', name: 'Pedro Santos', service: 'Corte de cabelo', status: 'concluído', statusColor: 'text-text-muted bg-white/[0.04] border-white/[0.06]', avatar: 'PS' },
                  { time: '10:30', name: 'Lucas Oliveira', service: 'Barba', status: 'em andamento', statusColor: 'text-brand-400 bg-brand-500/10 border-brand-500/20', avatar: 'LO' },
                  { time: '11:00', name: 'Rafael Costa', service: 'Corte + Sobrancelha', status: 'pendente', statusColor: 'text-yellow-400 bg-yellow-500/10 border-yellow-500/20', avatar: 'RC' },
                ].map((row) => (
                  <div class="flex items-center justify-between rounded-lg border border-white/[0.04] px-3 py-2.5 text-sm transition-colors hover:bg-white/[0.02] cursor-pointer group">
                    <div class="flex items-center gap-3">
                      <span class="font-mono text-[11px] text-text-muted w-10 text-right">{row.time}</span>
                      <div class="hidden sm:flex h-7 w-7 items-center justify-center rounded-full bg-white/[0.06] text-[10px] font-medium text-text-secondary">
                        {row.avatar}
                      </div>
                      <div class="flex flex-col">
                          <span class="text-sm text-white">{row.name}</span>
                          <span class="text-[11px] text-text-muted sm:hidden">{row.service}</span>
                      </div>
                    </div>
                    <div class="flex items-center gap-3">
                      <span class="hidden text-[12px] text-text-muted sm:inline">{row.service}</span>
                      <span class={`rounded-md border px-1.5 py-0.5 text-[10px] font-medium uppercase tracking-wide ${row.statusColor}`}>{row.status}</span>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  document.addEventListener('demo:booking-completed', (event: any) => {
    const data = event.detail;

    const statAgendamentos = document.getElementById('stat-agendamentos');
    const cardAgendamentos = document.getElementById('card-agendamentos');
    if (statAgendamentos && cardAgendamentos) {
      const current = parseInt(statAgendamentos.innerText) || 12;
      statAgendamentos.innerText = (current + 1).toString();
      cardAgendamentos.classList.add('border-brand-500/30');
      setTimeout(() => cardAgendamentos.classList.remove('border-brand-500/30'), 1500);
    }

    const statFaturamento = document.getElementById('stat-faturamento');
    const cardFaturamento = document.getElementById('card-faturamento');
    const novoValor = data.price || 35;
    if (statFaturamento && cardFaturamento) {
       const atualText = statFaturamento.innerText.replace(/R\$\s*/, '').replace(/\./g, '');
       const total = (parseInt(atualText) || 540) + novoValor;
       statFaturamento.innerHTML = `<span class="text-sm text-text-muted">R$</span> ${total}`;
       cardFaturamento.classList.add('border-emerald-500/30');
       setTimeout(() => cardFaturamento.classList.remove('border-emerald-500/30'), 1500);
    }

    const toast = document.getElementById('demo-notification');
    if (toast) {
       toast.classList.remove('translate-x-full', 'opacity-0');
       setTimeout(() => toast.classList.add('translate-x-full', 'opacity-0'), 4000);
    }

    const container = document.getElementById('agenda-rows-container');
    if (container) {
      const rowHtml = `
        <div class="flex items-center justify-between rounded-lg border border-brand-500/20 bg-brand-500/[0.05] px-3 py-2.5 text-sm cursor-pointer group relative overflow-hidden transform scale-95 opacity-0 transition-all duration-500" id="new-booking-row">
          <div class="flex items-center gap-3">
            <span class="font-mono text-[11px] font-medium text-brand-400 w-10 text-right">${data.time}</span>
            <div class="hidden sm:flex h-7 w-7 items-center justify-center rounded-full bg-brand-500/20 text-[10px] font-medium text-brand-300">
              J
            </div>
            <div class="flex flex-col">
                <span class="text-sm text-white">${data.name}</span>
                <span class="text-[11px] text-brand-300 sm:hidden">${data.service}</span>
            </div>
          </div>
          <div class="flex items-center gap-3">
            <span class="hidden text-[12px] text-brand-200/70 sm:inline">${data.service}</span>
            <span class="rounded-md border px-1.5 py-0.5 text-[10px] font-medium uppercase tracking-wide text-emerald-400 bg-emerald-500/10 border-emerald-500/20">NOVO</span>
          </div>
        </div>
      `;

      container.insertAdjacentHTML('afterbegin', rowHtml);

      setTimeout(() => {
        const newRow = document.getElementById('new-booking-row');
        if (newRow) {
          newRow.classList.remove('scale-95', 'opacity-0');
          setTimeout(() => {
            newRow.classList.remove('bg-brand-500/[0.05]', 'border-brand-500/20');
            newRow.classList.add('bg-transparent', 'border-white/[0.04]');
            const badge = newRow.querySelector('span.rounded-md');
            if (badge) {
               badge.className = 'rounded-md border px-1.5 py-0.5 text-[10px] font-medium uppercase tracking-wide text-yellow-400 bg-yellow-500/10 border-yellow-500/20 transition-all';
               badge.innerText = 'PENDENTE';
            }
          }, 3000);
        }
      }, 50);
    }
  });
</script>
