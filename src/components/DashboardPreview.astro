---
---

<section class="py-20 sm:py-28">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="animate-on-scroll text-center">
      <h2 class="text-3xl font-bold sm:text-4xl">
        Gerencie tudo em um painel
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-text-secondary">
        Interface intuitiva com notificações em tempo real, agenda visual e controle financeiro completo.
      </p>
    </div>

    <!-- Browser frame -->
    <div class="animate-on-scroll mx-auto mt-12 max-w-5xl">
      <div class="overflow-hidden rounded-xl border border-border shadow-2xl shadow-black/40">
        <!-- Browser chrome -->
        <div class="flex items-center gap-2 bg-bg-elevated px-4 py-3">
          <div class="flex gap-1.5">
            <div class="h-3 w-3 rounded-full bg-red-500/80"></div>
            <div class="h-3 w-3 rounded-full bg-yellow-500/80"></div>
            <div class="h-3 w-3 rounded-full bg-green-500/80"></div>
          </div>
          <div class="ml-4 flex-1 rounded-md bg-bg-primary/60 px-3 py-1.5">
            <p class="text-xs text-text-muted">vitor-aleixo.cortezap.app.br</p>
          </div>
        </div>

        <!-- Dashboard content placeholder -->
        <div class="bg-bg-primary p-6 sm:p-8">
          <div class="grid gap-4 sm:grid-cols-4">
            <!-- Stat cards -->
            <div class="rounded-lg border border-border bg-bg-card p-4">
              <p class="text-xs text-text-muted">Hoje</p>
              <p class="mt-1 text-2xl font-bold text-brand-400">12</p>
              <p class="text-xs text-text-secondary">agendamentos</p>
            </div>
            <div class="rounded-lg border border-border bg-bg-card p-4">
              <p class="text-xs text-text-muted">Semana</p>
              <p class="mt-1 text-2xl font-bold text-text-primary">67</p>
              <p class="text-xs text-text-secondary">agendamentos</p>
            </div>
            <div class="rounded-lg border border-border bg-bg-card p-4">
              <p class="text-xs text-text-muted">Faturamento</p>
              <p class="mt-1 text-2xl font-bold text-green-400">R$ 4.280</p>
              <p class="text-xs text-text-secondary">este mês</p>
            </div>
            <div class="rounded-lg border border-border bg-bg-card p-4">
              <p class="text-xs text-text-muted">Clientes</p>
              <p class="mt-1 text-2xl font-bold text-text-primary">248</p>
              <p class="text-xs text-text-secondary">cadastrados</p>
            </div>
          </div>

          <!-- Fake agenda rows -->
          <div class="mt-6 rounded-lg border border-border bg-bg-card p-4">
            <div class="mb-3 flex items-center justify-between">
              <p class="text-sm font-semibold">Agenda de hoje</p>
              <span class="rounded-full bg-brand-500/10 px-2.5 py-0.5 text-xs font-medium text-brand-400">12 agendamentos</span>
            </div>
            <div class="space-y-2">
              {[
                { time: '09:00', name: 'João Silva', service: 'Corte + Barba', status: 'confirmado', statusColor: 'text-green-400 bg-green-400/10' },
                { time: '09:45', name: 'Pedro Santos', service: 'Corte de cabelo', status: 'confirmado', statusColor: 'text-green-400 bg-green-400/10' },
                { time: '10:30', name: 'Lucas Oliveira', service: 'Barba', status: 'pendente', statusColor: 'text-brand-400 bg-brand-400/10' },
                { time: '11:00', name: 'Rafael Costa', service: 'Corte + Sobrancelha', status: 'pendente', statusColor: 'text-brand-400 bg-brand-400/10' },
              ].map((row) => (
                <div class="flex items-center justify-between rounded-md bg-bg-primary/50 px-3 py-2.5 text-sm">
                  <div class="flex items-center gap-3">
                    <span class="font-mono text-xs text-text-muted">{row.time}</span>
                    <span class="font-medium">{row.name}</span>
                  </div>
                  <div class="flex items-center gap-3">
                    <span class="hidden text-xs text-text-secondary sm:inline">{row.service}</span>
                    <span class={`rounded-full px-2 py-0.5 text-xs font-medium ${row.statusColor}`}>{row.status}</span>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
