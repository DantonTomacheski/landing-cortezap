---
---

<section class="relative py-24 sm:py-32">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="animate-on-scroll text-center flex flex-col items-center">
      <div class="mb-4 inline-flex items-center rounded-full border border-brand-500/20 bg-brand-500/10 px-3 py-1 text-sm font-medium text-brand-400">
        Gestão Visual
      </div>
      <h2 class="mt-2 text-4xl font-black tracking-tight sm:text-5xl text-white">
        Painel para barbeiro e gestão completa
      </h2>
      <p class="mt-6 max-w-2xl text-lg text-text-secondary font-light">
        Interface intuitiva com notificações em tempo real, agenda visual, clientes e controle financeiro completo.
      </p>
    </div>

    <!-- Browser frame with glassmorphism -->
    <div class="animate-on-scroll mx-auto mt-20 max-w-5xl relative group perspective-1000">
      <div class="absolute -inset-1 rounded-[1.5rem] bg-gradient-to-tr from-brand-500/20 to-brand-600/20 blur-2xl transition duration-500 group-hover:from-brand-500/40 group-hover:to-brand-600/40 opacity-50"></div>
      
      <div class="relative overflow-hidden rounded-2xl border border-white/10 shadow-2xl backdrop-blur-3xl bg-[#0A0A0A]/80 transition-transform duration-500 hover:-translate-y-2">
        <!-- Browser chrome -->
        <div class="flex items-center gap-2 bg-white/5 px-4 py-3 border-b border-white/10">
          <div class="flex gap-2">
            <div class="h-3 w-3 rounded-full bg-red-500/80 shadow-[inset_0_1px_1px_rgba(255,255,255,0.2)]"></div>
            <div class="h-3 w-3 rounded-full bg-yellow-500/80 shadow-[inset_0_1px_1px_rgba(255,255,255,0.2)]"></div>
            <div class="h-3 w-3 rounded-full bg-green-500/80 shadow-[inset_0_1px_1px_rgba(255,255,255,0.2)]"></div>
          </div>
          <div class="ml-4 flex-1 rounded-md bg-black/40 px-3 py-1.5 border border-white/5 flex justify-center items-center">
            <p class="text-[12px] font-mono text-text-muted flex items-center gap-2"><svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg> vitor-aleixo.cortezap.app.br</p>
          </div>
          <div class="w-16"></div> <!-- Spacer for center alignment -->
        </div>

        <!-- Dashboard content spacer -->
        <div class="p-6 sm:p-8">
          <div class="grid gap-4 sm:grid-cols-4">
            <!-- Stat cards -->
            <div class="rounded-xl border border-white/5 bg-white/[0.02] p-5 backdrop-blur-sm transition-colors hover:bg-white/[0.04]">
              <p class="text-xs font-medium text-text-muted uppercase tracking-wider">Hoje</p>
              <p class="mt-2 text-3xl font-black text-white">12</p>
              <p class="mt-1 text-xs text-brand-400 font-medium">+3 desde ontem</p>
            </div>
            <div class="rounded-xl border border-white/5 bg-white/[0.02] p-5 backdrop-blur-sm transition-colors hover:bg-white/[0.04]">
              <p class="text-xs font-medium text-text-muted uppercase tracking-wider">Semana</p>
              <p class="mt-2 text-3xl font-black text-white">67</p>
              <p class="mt-1 text-xs text-green-400 font-medium">+12% vs última</p>
            </div>
            <div class="rounded-xl border border-white/5 bg-white/[0.02] p-5 backdrop-blur-sm transition-colors hover:bg-white/[0.04]">
              <p class="text-xs font-medium text-text-muted uppercase tracking-wider">Faturamento</p>
              <p class="mt-2 text-3xl font-black text-white">R$ 4.280</p>
              <p class="mt-1 text-xs text-green-400 font-medium">Este mês</p>
            </div>
            <div class="rounded-xl border border-white/5 bg-white/[0.02] p-5 backdrop-blur-sm transition-colors hover:bg-white/[0.04]">
              <p class="text-xs font-medium text-text-muted uppercase tracking-wider">Clientes</p>
              <p class="mt-2 text-3xl font-black text-white">248</p>
              <p class="mt-1 text-xs text-text-secondary font-medium">Cadastrados</p>
            </div>
          </div>

          <!-- Fake agenda rows -->
          <div class="mt-6 rounded-xl border border-white/5 bg-white/[0.02] p-5 backdrop-blur-sm">
            <div class="mb-5 flex items-center justify-between">
              <p class="text-base font-bold text-white">Agenda de hoje</p>
              <span class="rounded-full border border-brand-500/20 bg-brand-500/10 px-3 py-1 text-xs font-semibold text-brand-400 shadow-sm">12 agendamentos</span>
            </div>
            <div class="space-y-3">
              {[
                { time: '09:00', name: 'João Silva', service: 'Corte + Barba', status: 'confirmado', statusColor: 'text-green-300 bg-green-500/10 border-green-500/20', avatar: 'JS' },
                { time: '09:45', name: 'Pedro Santos', service: 'Corte de cabelo', status: 'confirmado', statusColor: 'text-green-300 bg-green-500/10 border-green-500/20', avatar: 'PS' },
                { time: '10:30', name: 'Lucas Oliveira', service: 'Barba', status: 'pendente', statusColor: 'text-brand-300 bg-brand-500/10 border-brand-500/20', avatar: 'LO' },
                { time: '11:00', name: 'Rafael Costa', service: 'Corte + Sobrancelha', status: 'pendente', statusColor: 'text-brand-300 bg-brand-500/10 border-brand-500/20', avatar: 'RC' },
              ].map((row) => (
                <div class="flex items-center justify-between rounded-lg border border-white/5 bg-black/20 px-4 py-3 text-sm transition-colors hover:bg-black/40 cursor-pointer">
                  <div class="flex items-center gap-4">
                    <span class="font-mono text-xs font-medium text-text-muted w-10">{row.time}</span>
                    <div class="hidden sm:flex h-8 w-8 items-center justify-center rounded-full bg-white/10 text-xs font-bold text-white">
                      {row.avatar}
                    </div>
                    <div class="flex flex-col">
                        <span class="font-semibold text-white">{row.name}</span>
                        <span class="text-xs text-text-secondary sm:hidden">{row.service}</span>
                    </div>
                  </div>
                  <div class="flex items-center gap-4">
                    <span class="hidden text-[13px] font-medium text-text-secondary sm:inline">{row.service}</span>
                    <span class={`rounded-full border px-2.5 py-1 text-[11px] font-bold uppercase tracking-wider ${row.statusColor}`}>{row.status}</span>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
