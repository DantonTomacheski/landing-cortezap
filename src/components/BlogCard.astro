---
interface Props {
  post: {
    id: string;
    data: {
      title: string;
      description: string;
      clusterLabel: string;
      readingTime: number;
      publishedAt: string;
      tags: string[];
    };
  };
  compact?: boolean;
}

const { post, compact = false } = Astro.props;
const url = `/blog/${post.id}`;
---

<article class="group rounded-2xl border border-white/10 bg-white/[0.02] p-5 transition-all duration-300 hover:-translate-y-1 hover:border-brand-500/30 hover:bg-white/[0.04]">
  <div class="flex items-center justify-between gap-4">
    <span class="inline-flex rounded-full border border-white/10 bg-white/[0.04] px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.14em] text-brand-300">
      {post.data.clusterLabel}
    </span>
    <span class="text-xs text-text-muted">{post.data.readingTime} min</span>
  </div>

  <h3 class={`mt-4 font-black tracking-tight text-white transition-colors group-hover:text-brand-300 ${compact ? "text-lg" : "text-2xl"}`}>
    <a href={url}>{post.data.title}</a>
  </h3>

  <p class={`mt-3 leading-relaxed text-text-secondary ${compact ? "text-sm" : "text-base"}`}>
    {post.data.description}
  </p>

  <div class="mt-5 flex flex-wrap gap-2">
    {post.data.tags.slice(0, compact ? 2 : 3).map((tag) => (
      <span class="rounded-full bg-white/[0.04] px-3 py-1 text-[11px] font-medium text-text-secondary">
        {tag}
      </span>
    ))}
  </div>

  <div class="mt-6 flex items-center justify-between gap-4">
    <time datetime={post.data.publishedAt} class="text-xs text-text-muted">
      {new Intl.DateTimeFormat("pt-BR", {
        day: "2-digit",
        month: "short",
        year: "numeric",
      }).format(new Date(post.data.publishedAt))}
    </time>

    <a
      href={url}
      class="inline-flex items-center gap-2 text-sm font-semibold text-white transition-colors hover:text-brand-300"
    >
      Ler artigo
      <span aria-hidden="true">&rarr;</span>
    </a>
  </div>
</article>
