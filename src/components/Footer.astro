---
import { Image } from 'astro:assets';
import logo from '../assets/logo.png';

const links = [
  { label: 'Funcionalidades', href: '#funcionalidades' },
  { label: 'Como funciona', href: '#como-funciona' },
  { label: 'Planos', href: '#planos' },
  { label: 'FAQ', href: '#faq' },
];
---

<footer class="border-t border-border bg-bg-primary">
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="flex flex-col items-center gap-8 md:flex-row md:justify-between">
      <div class="flex flex-col items-center gap-4 md:items-start">
        <Image src={logo} alt="CorteZap" width={120} height={34} class="h-7 w-auto" />
        <p class="text-sm text-text-muted">
          Agendamento inteligente pelo WhatsApp para barbearias.
        </p>
      </div>

      <nav class="flex flex-wrap justify-center gap-6">
        {links.map((link) => (
          <a
            href={link.href}
            class="text-sm text-text-secondary transition-colors hover:text-brand-400"
          >
            {link.label}
          </a>
        ))}
      </nav>
    </div>

    <div class="mt-8 border-t border-border pt-8 text-center">
      <p class="text-xs text-text-muted">
        &copy; {new Date().getFullYear()} CorteZap. Todos os direitos reservados.
      </p>
    </div>
  </div>
</footer>
