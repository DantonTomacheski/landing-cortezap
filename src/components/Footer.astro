---
import { Image } from 'astro:assets';
import logo from '../assets/logo.png';

const links = [
  { label: 'Funcionalidades', href: '#funcionalidades' },
  { label: 'Como funciona', href: '#como-funciona' },
  { label: 'Planos', href: '#planos' },
  { label: 'FAQ', href: '#faq' },
];
---

<footer class="border-t border-white/10 bg-[#050505]">
  <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="flex flex-col items-center gap-8 md:flex-row md:justify-between">
      <div class="flex flex-col items-center gap-4 md:items-start">
        <Image src={logo} alt="CorteZap" width={861} height={209} class="h-8 sm:h-10 w-auto opacity-90" />
        <p class="text-sm text-text-muted font-light max-w-xs text-center md:text-left">
          Inteligência Artificial e gestão completa para transformar sua barbearia.
        </p>
      </div>

      <nav class="flex flex-wrap justify-center gap-8">
        {links.map((link) => (
          <a
            href={link.href}
            class="text-[15px] font-medium text-text-secondary transition-colors hover:text-white"
          >
            {link.label}
          </a>
        ))}
      </nav>
    </div>

    <div class="mt-12 border-t border-white/10 pt-8 flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="text-xs text-text-muted/60">
        &copy; {new Date().getFullYear()} CorteZap. Todos os direitos reservados.
      </p>
      <div class="flex items-center gap-6">
        <a href="#" class="text-xs font-medium text-text-muted/60 hover:text-white transition-colors">Termos de Uso</a>
        <a href="#" class="text-xs font-medium text-text-muted/60 hover:text-white transition-colors">Privacidade</a>
      </div>
    </div>
  </div>
</footer>
