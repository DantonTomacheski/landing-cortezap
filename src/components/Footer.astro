---
const CDN_BASE = 'https://api-homolog.cortezap.app.br/cdn/img';

const isHome = Astro.url.pathname === '/';
const anchorPrefix = isHome ? '' : '/';

const links = [
  { label: 'Agendamento WhatsApp', href: '/agendamento-whatsapp-barbearia' },
  { label: 'Painel para barbeiro', href: '/painel-para-barbeiro' },
  { label: 'Sistema para barbearia', href: '/sistema-para-barbearia' },
  { label: 'Planos', href: `${anchorPrefix}#planos` },
  { label: 'FAQ', href: `${anchorPrefix}#faq` },
];
---

<footer data-testid="footer" class="border-t border-white/[0.06] bg-bg-primary">
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="flex flex-col items-center gap-8 md:flex-row md:justify-between">
      <div class="flex flex-col items-center gap-3 md:items-start">
        <img data-testid="footer-logo" src={`${CDN_BASE}/logo.png`} alt="CorteZap" width="861" height="209" class="h-7 w-auto opacity-70" />
        <p class="text-xs text-text-muted max-w-xs text-center md:text-left">
          Sistema para barbearia com agendamento no WhatsApp e painel para barbeiro.
        </p>
      </div>

      <nav data-testid="footer-nav" class="flex flex-wrap justify-center gap-6">
        {links.map((link) => (
          <a
            href={link.href}
            data-testid={`footer-link-${link.label.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '').replace(/\s+/g, '-')}`}
            class="text-sm text-text-muted transition-colors hover:text-white"
          >
            {link.label}
          </a>
        ))}
      </nav>
    </div>

    <div class="mt-8 border-t border-white/[0.06] pt-6 flex flex-col md:flex-row items-center justify-between gap-4">
      <div class="flex flex-col items-center md:items-start gap-1">
        <p class="text-[11px] text-text-muted">
          &copy; {new Date().getFullYear()} CorteZap. Todos os direitos reservados.
        </p>
        <div class="text-[11px] text-text-muted text-center md:text-left space-y-0.5">
          <p>65.305.950 DANTON BUDINHESKI TOMACHESKI · CNPJ: 65.305.950/0001-70</p>
        </div>
      </div>
      <div class="flex items-center gap-4">
        <a data-testid="footer-terms" href="/termos-de-uso" class="text-[11px] text-text-muted hover:text-white transition-colors">Termos</a>
        <a data-testid="footer-privacy" href="/politica-de-privacidade" class="text-[11px] text-text-muted hover:text-white transition-colors">Privacidade</a>
      </div>
    </div>
  </div>
</footer>
