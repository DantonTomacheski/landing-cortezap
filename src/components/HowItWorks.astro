---
const steps = [
  {
    number: '01',
    title: 'Cliente manda mensagem',
    description: 'Seu cliente envia uma mensagem no WhatsApp da barbearia, como faria normalmente. Via API Oficial da Meta — sem robô pirata, sem risco de banimento.',
  },
  {
    number: '02',
    title: 'IA entende e agenda',
    description: 'O bot com inteligência artificial interpreta a mensagem, verifica horários disponíveis e confirma o agendamento em segundos.',
  },
  {
    number: '03',
    title: 'Você gerencia no painel',
    description: 'Acompanhe agendamentos, finanças e clientes em tempo real no painel para barbeiro, com tudo sincronizado.',
  },
];
---

<section id="como-funciona" data-testid="how-it-works-section" class="relative py-24 sm:py-32">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="animate-on-scroll text-center">
      <h2 class="text-3xl font-semibold tracking-tight sm:text-4xl text-white">
        Como funciona
      </h2>
      <p class="mt-4 max-w-2xl mx-auto text-base text-text-secondary">
        Em 3 passos, você ativa o agendamento por WhatsApp e o painel da barbearia.
      </p>
    </div>

    <div class="mt-16 grid gap-px md:grid-cols-3 rounded-xl border border-white/[0.06] overflow-hidden bg-white/[0.06]">
      {steps.map((step, index) => (
        <div
          data-testid={`how-it-works-step-${step.number}`}
          class="animate-on-scroll flex flex-col bg-bg-primary p-8 sm:p-10"
          style={`animation-delay: ${index * 100}ms`}
        >
          <span class="text-sm font-mono text-text-muted">{step.number}</span>
          <h3 class="mt-3 text-lg font-semibold text-white">{step.title}</h3>
          <p class="mt-3 text-sm text-text-secondary leading-relaxed">{step.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
