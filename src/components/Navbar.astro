---
import { ABACATEPAY_LINK_DEFAULT } from '../data/seo';

const CDN_BASE = 'https://api-homolog.cortezap.app.br/cdn/img';

const isHome = Astro.url.pathname === '/';
const anchorPrefix = isHome ? '' : '/';

const navLinks = [
  { label: 'Funcionalidades', href: `${anchorPrefix}#funcionalidades` },
  { label: 'Como funciona', href: `${anchorPrefix}#como-funciona` },
  { label: 'Planos', href: `${anchorPrefix}#planos` },
  { label: 'FAQ', href: `${anchorPrefix}#faq` },
  { label: 'Blog', href: '/blog' },
];
---

<nav
  id="navbar"
  data-testid="navbar"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
>
  <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8">
    <a data-testid="navbar-logo" href="/" class="flex items-center gap-2">
      <img src={`${CDN_BASE}/logo.png`} alt="CorteZap" width="861" height="209" class="h-8 sm:h-9 w-auto" />
    </a>

    <!-- Desktop links -->
    <div class="hidden items-center gap-8 md:flex">
      {navLinks.map((link) => (
        <a
          href={link.href}
          data-testid={`navbar-link-${link.label.toLowerCase().replace(/\s+/g, '-')}`}
          class="text-sm text-text-secondary transition-colors hover:text-white"
        >
          {link.label}
        </a>
      ))}
      <a
        data-testid="navbar-cta"
        href={ABACATEPAY_LINK_DEFAULT}
        target="_blank"
        rel="noopener noreferrer"
        class="rounded-lg bg-white px-4 py-2 text-sm font-medium text-[#09090b] transition-colors hover:bg-zinc-200"
      >
        Assinar agora
      </a>
    </div>

    <!-- Mobile menu button -->
    <button
      id="mobile-menu-btn"
      data-testid="navbar-mobile-menu-btn"
      class="flex items-center justify-center rounded-lg p-2 text-text-secondary transition-colors hover:text-white md:hidden"
      aria-label="Abrir menu"
      aria-expanded="false"
    >
      <svg id="menu-icon-open" class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <svg id="menu-icon-close" class="hidden h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    data-testid="navbar-mobile-menu"
    class="hidden border-t border-white/[0.06] bg-[#09090b]/95 backdrop-blur-xl md:hidden"
  >
    <div class="flex flex-col gap-1 px-4 py-4">
      {navLinks.map((link) => (
        <a
          href={link.href}
          data-testid={`navbar-mobile-link-${link.label.toLowerCase().replace(/\s+/g, '-')}`}
          class="mobile-nav-link rounded-lg px-4 py-3 text-sm text-text-secondary transition-colors hover:bg-white/[0.04] hover:text-white"
        >
          {link.label}
        </a>
      ))}
      <a
        data-testid="navbar-mobile-cta"
        href={ABACATEPAY_LINK_DEFAULT}
        target="_blank"
        rel="noopener noreferrer"
        class="mt-3 rounded-lg bg-white px-5 py-3 text-center text-sm font-medium text-[#09090b] transition-colors hover:bg-zinc-200"
      >
        Assinar agora
      </a>
    </div>
  </div>
</nav>

<script>
  // Mobile menu toggle
  const btn = document.getElementById('mobile-menu-btn')!;
  const menu = document.getElementById('mobile-menu')!;
  const iconOpen = document.getElementById('menu-icon-open')!;
  const iconClose = document.getElementById('menu-icon-close')!;

  btn.addEventListener('click', () => {
    const isOpen = !menu.classList.contains('hidden');
    menu.classList.toggle('hidden');
    iconOpen.classList.toggle('hidden');
    iconClose.classList.toggle('hidden');
    btn.setAttribute('aria-expanded', String(!isOpen));
  });

  // Close menu on link click
  menu.querySelectorAll('.mobile-nav-link').forEach((link) => {
    link.addEventListener('click', () => {
      menu.classList.add('hidden');
      iconOpen.classList.remove('hidden');
      iconClose.classList.add('hidden');
      btn.setAttribute('aria-expanded', 'false');
    });
  });

  // Navbar scroll effect
  const navbar = document.getElementById('navbar')!;
  let lastScroll = 0;

  window.addEventListener('scroll', () => {
    const currentScroll = window.scrollY;
    if (currentScroll > 50) {
      navbar.classList.add('bg-[#09090b]/80', 'backdrop-blur-xl', 'border-b', 'border-white/[0.06]');
    } else {
      navbar.classList.remove('bg-[#09090b]/80', 'backdrop-blur-xl', 'border-b', 'border-white/[0.06]');
    }
    lastScroll = currentScroll;
  }, { passive: true });
</script>
