---
const whatsappLink = 'https://wa.me/5511999999999?text=Ol%C3%A1!%20Quero%20testar%20o%20CorteZap';
---

<section class="relative min-h-screen overflow-hidden pt-24 pb-16 sm:pt-32 sm:pb-24">
  <!-- Gradient orbs background -->
  <div class="pointer-events-none absolute inset-0">
    <div class="absolute -top-40 -left-40 h-96 w-96 rounded-full bg-brand-500/10 blur-3xl"></div>
    <div class="absolute top-1/4 -right-20 h-72 w-72 rounded-full bg-brand-600/8 blur-3xl"></div>
  </div>

  <div class="relative mx-auto flex max-w-7xl flex-col items-center gap-12 px-4 sm:px-6 lg:flex-row lg:gap-16 lg:px-8">
    <!-- Text content -->
    <div class="flex flex-1 flex-col items-center text-center lg:items-start lg:text-left">
      <div class="mb-4 inline-flex items-center gap-2 rounded-full border border-brand-500/20 bg-brand-500/10 px-4 py-1.5">
        <span class="h-2 w-2 rounded-full bg-brand-400 animate-pulse"></span>
        <span class="text-xs font-medium text-brand-300">7 dias grátis em qualquer plano</span>
      </div>

      <h1 class="max-w-2xl text-4xl font-bold leading-tight tracking-tight sm:text-5xl lg:text-6xl">
        Seu cliente agenda pelo
        <span class="bg-gradient-to-r from-brand-400 to-brand-600 bg-clip-text text-transparent">
          WhatsApp.
        </span>
        <br />
        Sem app, sem complicação.
      </h1>

      <p class="mt-6 max-w-xl text-lg text-text-secondary sm:text-xl">
        O CorteZap é um bot com IA que atende seus clientes no WhatsApp, agenda automaticamente e organiza toda sua barbearia em um painel completo.
      </p>

      <div class="mt-8 flex flex-col gap-4 sm:flex-row">
        <a
          href={whatsappLink}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center gap-2 rounded-xl bg-brand-500 px-8 py-4 text-base font-semibold text-white shadow-lg shadow-brand-500/25 transition-all hover:bg-brand-600 hover:shadow-brand-500/40 hover:-translate-y-0.5"
        >
          <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Comece grátis agora
        </a>
        <a
          href="#como-funciona"
          class="inline-flex items-center justify-center gap-2 rounded-xl border border-border px-8 py-4 text-base font-medium text-text-secondary transition-all hover:border-brand-500/30 hover:text-text-primary"
        >
          Veja como funciona
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
          </svg>
        </a>
      </div>
    </div>

    <!-- WhatsApp mockup -->
    <div class="flex-1 w-full max-w-md lg:max-w-lg">
      <div class="rounded-3xl border border-border bg-bg-card p-4 shadow-2xl shadow-black/30">
        <!-- Phone header -->
        <div class="flex items-center gap-3 rounded-t-2xl bg-[#075E54] px-4 py-3">
          <div class="flex h-10 w-10 items-center justify-center rounded-full bg-brand-500 text-sm font-bold text-white">CZ</div>
          <div>
            <p class="text-sm font-semibold text-white">CorteZap Bot</p>
            <p class="text-xs text-green-200">online</p>
          </div>
        </div>

        <!-- Chat area -->
        <div class="flex flex-col gap-2.5 bg-[#0B141A] px-3 py-4" style="background-image: url('data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%2220%22 height=%2220%22><rect width=%2220%22 height=%2220%22 fill=%22%230B141A%22/><circle cx=%2210%22 cy=%2210%22 r=%220.5%22 fill=%22%23ffffff08%22/></svg>');">
          <!-- Bot message 1 -->
          <div class="max-w-[85%] self-start rounded-lg rounded-tl-none bg-[#1F2C34] px-3 py-2">
            <p class="text-sm text-gray-100">Olá! Bem-vindo à <strong>Barbearia do Vitor</strong> ✂️</p>
            <p class="text-sm text-gray-100 mt-1">Como posso te ajudar?</p>
            <p class="mt-1 text-right text-[10px] text-gray-400">10:30</p>
          </div>

          <!-- User message -->
          <div class="max-w-[75%] self-end rounded-lg rounded-tr-none bg-[#005C4B] px-3 py-2">
            <p class="text-sm text-gray-100">Quero agendar um corte pra amanhã</p>
            <p class="mt-1 text-right text-[10px] text-gray-300">10:31</p>
          </div>

          <!-- Bot message 2 -->
          <div class="max-w-[85%] self-start rounded-lg rounded-tl-none bg-[#1F2C34] px-3 py-2">
            <p class="text-sm text-gray-100">Perfeito! Encontrei esses horários disponíveis para amanhã:</p>
            <div class="mt-2 flex flex-wrap gap-1.5">
              <span class="rounded-md bg-brand-500/20 px-2.5 py-1 text-xs font-medium text-brand-300">09:00</span>
              <span class="rounded-md bg-brand-500/20 px-2.5 py-1 text-xs font-medium text-brand-300">10:30</span>
              <span class="rounded-md bg-brand-500/20 px-2.5 py-1 text-xs font-medium text-brand-300">14:00</span>
              <span class="rounded-md bg-brand-500/20 px-2.5 py-1 text-xs font-medium text-brand-300">16:00</span>
            </div>
            <p class="mt-1 text-right text-[10px] text-gray-400">10:31</p>
          </div>

          <!-- User message 2 -->
          <div class="max-w-[75%] self-end rounded-lg rounded-tr-none bg-[#005C4B] px-3 py-2">
            <p class="text-sm text-gray-100">10:30</p>
            <p class="mt-1 text-right text-[10px] text-gray-300">10:31</p>
          </div>

          <!-- Bot confirmation -->
          <div class="max-w-[85%] self-start rounded-lg rounded-tl-none bg-[#1F2C34] px-3 py-2">
            <p class="text-sm text-gray-100">Agendado! ✅</p>
            <p class="text-sm text-gray-100 mt-1"><strong>Corte de cabelo</strong> amanhã às <strong>10:30</strong> com Vitor.</p>
            <p class="text-sm text-gray-100 mt-1">Te vejo lá! 💈</p>
            <p class="mt-1 text-right text-[10px] text-gray-400">10:31</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
