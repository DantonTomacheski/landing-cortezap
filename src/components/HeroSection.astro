---
import InteractiveWhatsApp from './InteractiveWhatsApp.astro';
---

<section data-testid="hero-section" class="relative min-h-screen overflow-hidden pt-24 pb-16 sm:pt-32 sm:pb-24 flex items-center">
  <!-- Dot grid -->
  <div class="absolute inset-0 bg-[radial-gradient(circle,rgba(255,255,255,0.03)_1px,transparent_1px)] bg-[size:24px_24px] [mask-image:radial-gradient(ellipse_80%_60%_at_50%_0%,black_40%,transparent_100%)]"></div>

  <!-- Atmospheric mesh gradient -->
  <div class="pointer-events-none absolute inset-0">
    <div class="absolute top-[-20%] left-[-10%] w-[60%] h-[60%] rounded-full bg-[radial-gradient(circle,rgba(120,80,200,0.07),transparent_70%)]"></div>
    <div class="absolute bottom-[-10%] right-[-10%] w-[50%] h-[50%] rounded-full bg-[radial-gradient(circle,rgba(60,120,220,0.05),transparent_70%)]"></div>
  </div>

  <div class="relative mx-auto flex w-full max-w-7xl flex-col items-center gap-12 px-4 sm:px-6 lg:flex-row lg:gap-16 lg:px-8 z-10">
    <!-- Text content -->
    <div class="flex flex-1 flex-col items-center text-center lg:items-start lg:text-left">
      <div class="mb-6 inline-flex items-center gap-2 rounded-lg border border-white/[0.06] bg-white/[0.03] px-3 py-1.5">
        <div class="h-1.5 w-1.5 rounded-full bg-emerald-400"></div>
        <span class="text-xs text-text-secondary">API Oficial da Meta — Sem risco de banimento</span>
      </div>

      <h1 class="max-w-2xl text-4xl font-semibold leading-[1.1] tracking-tight sm:text-5xl lg:text-6xl">
        Agendamento de barbearia
        <span class="text-brand-500"> pelo WhatsApp.</span>
      </h1>

      <p class="mt-6 max-w-lg text-base text-text-secondary leading-relaxed sm:text-lg">
        Sistema para barbearia com bot inteligente no WhatsApp e painel completo para barbeiro. <span class="text-white">Sem app extra para cliente.</span>
      </p>

      <div class="mt-10 flex flex-col gap-3 sm:flex-row w-full sm:w-auto">
        <a
          data-testid="hero-cta-primary"
          href="#planos"
          class="inline-flex items-center justify-center gap-2 rounded-lg bg-brand-500 px-6 py-3 text-sm font-medium text-white transition-colors hover:bg-brand-600"
        >
          Começar agora
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
          </svg>
        </a>
        <a
          data-testid="hero-cta-secondary"
          href="#como-funciona"
          class="inline-flex items-center justify-center gap-2 rounded-lg px-6 py-3 text-sm text-text-secondary transition-colors hover:text-white"
        >
          Veja como funciona
          <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
          </svg>
        </a>
      </div>

      <div class="mt-10 flex flex-col sm:flex-row items-center gap-4 sm:gap-6 text-xs text-text-muted">
        <div class="flex items-center gap-2">
          <svg class="h-3.5 w-3.5 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
          API Oficial da Meta
        </div>
        <div class="flex items-center gap-2">
          <svg class="h-3.5 w-3.5 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
          Zero risco de banimento
        </div>
        <div class="flex items-center gap-2">
          <svg class="h-3.5 w-3.5 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
          Setup em 10 minutos
        </div>
      </div>
    </div>

    <!-- WhatsApp mockup -->
    <InteractiveWhatsApp />
  </div>
</section>
