---
import { ABACATEPAY_LINK_DEFAULT } from '../data/seo';
import InteractiveWhatsApp from './InteractiveWhatsApp.astro';
---

<section class="relative min-h-screen overflow-hidden pt-24 pb-16 sm:pt-32 sm:pb-24 flex items-center">
  <!-- Dynamic modern grid background -->
  <div class="absolute inset-0 bg-[linear-gradient(to_right,#ffffff08_1px,transparent_1px),linear-gradient(to_bottom,#ffffff08_1px,transparent_1px)] bg-[size:4rem_4rem] [mask-image:radial-gradient(ellipse_80%_50%_at_50%_0%,#000_70%,transparent_100%)]"></div>
  
  <!-- Subtle ambient glow -->
  <div class="absolute left-1/2 top-0 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[400px] bg-brand-500/20 blur-[120px] rounded-full pointer-events-none"></div>

  <div class="relative mx-auto flex w-full max-w-7xl flex-col items-center gap-12 px-4 sm:px-6 lg:flex-row lg:gap-16 lg:px-8 z-10">
    <!-- Text content -->
    <div class="flex flex-1 flex-col items-center text-center lg:items-start lg:text-left">
      <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/5 px-4 py-1.5 backdrop-blur-md">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-brand-400 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-brand-500"></span>
        </span>
        <span class="text-xs font-medium tracking-wide text-brand-300 uppercase">API Oficial da Meta — Sem risco de banimento</span>
      </div>

      <h1 class="max-w-2xl text-5xl font-black leading-none tracking-tighter sm:text-6xl lg:text-7xl">
        Agendamento de barbearia <br/>
        <span class="inline-block bg-gradient-to-r from-brand-400 via-brand-500 to-brand-600 bg-clip-text text-transparent pb-2">
          pelo WhatsApp.
        </span>
      </h1>

      <p class="mt-6 max-w-xl text-lg text-text-secondary sm:text-xl font-light leading-relaxed">
        O CorteZap é um sistema para barbearia com bot inteligente no WhatsApp e painel para barbeiro. <strong class="text-white font-medium">Sem app extra para cliente.</strong>
      </p>

      <div class="mt-10 flex flex-col gap-4 sm:flex-row w-full sm:w-auto">
        <a
          href={ABACATEPAY_LINK_DEFAULT}
          target="_blank"
          rel="noopener noreferrer"
          class="group relative inline-flex items-center justify-center gap-2 rounded-xl bg-brand-500 px-8 py-4 text-base font-bold text-white transition-all hover:bg-brand-400 hover:scale-[1.02] overflow-hidden shadow-[0_0_20px_rgba(249,115,22,0.3)] hover:shadow-[0_0_30px_rgba(249,115,22,0.5)]"
        >
          <!-- Shimmer effect -->
          <div class="absolute inset-0 -translate-x-full bg-gradient-to-r from-transparent via-white/20 to-transparent group-hover:animate-shimmer"></div>

          <svg class="h-5 w-5 relative z-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
          </svg>
          <span class="relative z-10">Começar agora</span>
        </a>
        <a
          href="#como-funciona"
          class="inline-flex items-center justify-center gap-2 rounded-xl border border-white/10 bg-white/5 backdrop-blur-md px-8 py-4 text-base font-medium text-white transition-all hover:bg-white/10 hover:border-white/20"
        >
          Veja como funciona
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
          </svg>
        </a>
      </div>
      
      <div class="mt-8 flex flex-col sm:flex-row items-center gap-4 sm:gap-6 text-sm font-medium text-text-secondary/80">
        <div class="flex items-center gap-2">
          <svg class="h-5 w-5 text-brand-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
          Integração com API Oficial da Meta
        </div>
        <div class="flex items-center gap-2">
          <svg class="h-5 w-5 text-brand-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
          Zero Risco de Banimento
        </div>
      </div>
    </div>

    <!-- WhatsApp mockup with Glassmorphism -->
    <InteractiveWhatsApp />
  </div>
</section>

<style>
  @keyframes shimmer {
    100% {
      transform: translateX(100%);
    }
  }
  .animate-shimmer {
    animation: shimmer 2s infinite;
  }
</style>
