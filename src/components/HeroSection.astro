---
const whatsappLink = 'https://wa.me/5542999689501?text=Ol%C3%A1!%20Quero%20testar%20o%20CorteZap';
---

<section class="relative min-h-screen overflow-hidden pt-24 pb-16 sm:pt-32 sm:pb-24 flex items-center">
  <!-- Dynamic modern grid background -->
  <div class="absolute inset-0 bg-[linear-gradient(to_right,#ffffff08_1px,transparent_1px),linear-gradient(to_bottom,#ffffff08_1px,transparent_1px)] bg-[size:4rem_4rem] [mask-image:radial-gradient(ellipse_80%_50%_at_50%_0%,#000_70%,transparent_100%)]"></div>
  
  <!-- Subtle ambient glow -->
  <div class="absolute left-1/2 top-0 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[400px] bg-brand-500/20 blur-[120px] rounded-full pointer-events-none"></div>

  <div class="relative mx-auto flex w-full max-w-7xl flex-col items-center gap-12 px-4 sm:px-6 lg:flex-row lg:gap-16 lg:px-8 z-10">
    <!-- Text content -->
    <div class="flex flex-1 flex-col items-center text-center lg:items-start lg:text-left">
      <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/5 px-4 py-1.5 backdrop-blur-md">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-brand-400 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-brand-500"></span>
        </span>
        <span class="text-xs font-medium tracking-wide text-brand-300 uppercase">7 dias grátis em qualquer plano</span>
      </div>

      <h1 class="max-w-2xl text-5xl font-black leading-[1.05] tracking-tighter sm:text-6xl lg:text-7xl">
        Seu cliente agenda pelo <br/>
        <span class="inline-block bg-gradient-to-r from-brand-400 via-brand-500 to-brand-600 bg-clip-text text-transparent pb-2">
          WhatsApp.
        </span>
      </h1>

      <p class="mt-6 max-w-xl text-lg text-text-secondary sm:text-xl font-light leading-relaxed">
        O CorteZap é um bot inteligente que atende, agenda e organiza toda a sua barbearia. <strong class="text-white font-medium">Sem apps extras, sem enrolação.</strong>
      </p>

      <div class="mt-10 flex flex-col gap-4 sm:flex-row w-full sm:w-auto">
        <a
          href={whatsappLink}
          target="_blank"
          rel="noopener noreferrer"
          class="group relative inline-flex items-center justify-center gap-2 rounded-xl bg-brand-500 px-8 py-4 text-base font-semibold text-white transition-all hover:bg-brand-600 hover:scale-[1.02] overflow-hidden"
        >
          <!-- Shimmer effect -->
          <div class="absolute inset-0 -translate-x-full bg-gradient-to-r from-transparent via-white/20 to-transparent group-hover:animate-shimmer"></div>
          
          <svg class="h-5 w-5 relative z-10" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          <span class="relative z-10">Comece grátis agora</span>
        </a>
        <a
          href="#como-funciona"
          class="inline-flex items-center justify-center gap-2 rounded-xl border border-white/10 bg-white/5 backdrop-blur-md px-8 py-4 text-base font-medium text-white transition-all hover:bg-white/10 hover:border-white/20"
        >
          Veja como funciona
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
          </svg>
        </a>
      </div>
    </div>

    <!-- WhatsApp mockup with Glassmorphism -->
    <div class="flex-1 w-full max-w-md lg:max-w-lg relative group perspective-1000">
      <!-- Glow behind mockup -->
      <div class="absolute -inset-1 rounded-[2.5rem] bg-gradient-to-tr from-brand-500/30 to-brand-600/30 blur-2xl transition duration-500 group-hover:from-brand-500/50 group-hover:to-brand-600/50 group-hover:blur-3xl"></div>
      
      <!-- Outer glass border -->
      <div class="relative rounded-[2.5rem] border border-white/10 bg-black/40 p-3 shadow-2xl backdrop-blur-2xl transition-transform duration-500 hover:rotate-y-[-5deg] hover:rotate-x-[5deg]">
        <!-- Inner phone screen -->
        <div class="overflow-hidden rounded-3xl border border-white/5 bg-[#0A0A0A]">
          <!-- Phone header -->
          <div class="flex items-center gap-3 bg-[#075E54] px-4 py-3 border-b border-white/10">
            <div class="flex h-10 w-10 items-center justify-center rounded-full bg-brand-500 text-sm font-bold text-white shadow-inner">CZ</div>
            <div>
              <p class="text-sm font-semibold text-white tracking-wide">CorteZap Bot</p>
              <p class="text-xs text-green-200">online</p>
            </div>
            <div class="ml-auto flex gap-4 text-white/70">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"></path></svg>
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
            </div>
          </div>

          <!-- Chat area -->
          <div class="flex flex-col gap-3 bg-[#0B141A] px-4 py-5" style="background-image: url('data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%2220%22 height=%2220%22><rect width=%2220%22 height=%2220%22 fill=%22%23080c10%22/><circle cx=%2210%22 cy=%2210%22 r=%220.5%22 fill=%22%23ffffff05%22/></svg>');">
            <!-- Bot message 1 -->
            <div class="max-w-[85%] self-start rounded-2xl rounded-tl-none bg-[#1F2C34] px-4 py-2.5 shadow-sm border border-white/5 animate-on-scroll">
              <p class="text-[15px] leading-snug text-[#E9EDEF]">Olá! Bem-vindo à <strong class="text-white">Barbearia do Vitor</strong> ✂️</p>
              <p class="text-[15px] leading-snug text-[#E9EDEF] mt-1">Como posso te ajudar?</p>
              <p class="mt-1 text-right text-[11px] text-gray-400">10:30</p>
            </div>

            <!-- User message -->
            <div class="max-w-[75%] self-end rounded-2xl rounded-tr-none bg-[#005C4B] px-4 py-2.5 shadow-sm animate-on-scroll" style="animation-delay: 200ms;">
              <p class="text-[15px] leading-snug text-[#E9EDEF]">Quero agendar um corte pra amanhã</p>
              <p class="mt-1 text-right text-[11px] text-green-300">10:31 <span class="text-green-400 tracking-tighter ml-1">✓✓</span></p>
            </div>

            <!-- Bot message 2 -->
            <div class="max-w-[85%] self-start rounded-2xl rounded-tl-none bg-[#1F2C34] px-4 py-2.5 shadow-sm border border-white/5 animate-on-scroll" style="animation-delay: 400ms;">
              <p class="text-[15px] leading-snug text-[#E9EDEF]">Perfeito! Encontrei esses horários disponíveis para amanhã:</p>
              <div class="mt-3 flex flex-wrap gap-2">
                <span class="rounded-lg bg-brand-500/20 border border-brand-500/30 px-3 py-1.5 text-xs font-semibold text-brand-300 transition-colors hover:bg-brand-500 hover:text-white cursor-pointer">09:00</span>
                <span class="rounded-lg bg-brand-500/20 border border-brand-500/30 px-3 py-1.5 text-xs font-semibold text-brand-300 transition-colors hover:bg-brand-500 hover:text-white cursor-pointer">10:30</span>
                <span class="rounded-lg bg-brand-500/20 border border-brand-500/30 px-3 py-1.5 text-xs font-semibold text-brand-300 transition-colors hover:bg-brand-500 hover:text-white cursor-pointer">14:00</span>
                <span class="rounded-lg bg-brand-500/20 border border-brand-500/30 px-3 py-1.5 text-xs font-semibold text-brand-300 transition-colors hover:bg-brand-500 hover:text-white cursor-pointer">16:00</span>
              </div>
              <p class="mt-2 text-right text-[11px] text-gray-400">10:31</p>
            </div>

            <!-- User message 2 -->
            <div class="max-w-[75%] self-end rounded-2xl rounded-tr-none bg-[#005C4B] px-4 py-2.5 shadow-sm animate-on-scroll" style="animation-delay: 600ms;">
              <p class="text-[15px] leading-snug text-[#E9EDEF]">10:30</p>
              <p class="mt-1 text-right text-[11px] text-green-300">10:31 <span class="text-green-400 tracking-tighter ml-1">✓✓</span></p>
            </div>

            <!-- Bot confirmation -->
            <div class="max-w-[85%] self-start rounded-2xl rounded-tl-none bg-[#1F2C34] px-4 py-2.5 shadow-sm border border-brand-500/20 animate-on-scroll" style="animation-delay: 800ms;">
              <p class="text-[15px] leading-snug text-[#E9EDEF]">Agendado! ✅</p>
              <div class="my-2 p-2 rounded-lg bg-black/20 border border-white/5">
                <p class="text-[14px] text-[#E9EDEF]"><strong>💈 Corte de cabelo</strong></p>
                <p class="text-[13px] text-gray-300 mt-1">🕒 Amanhã às 10:30</p>
                <p class="text-[13px] text-gray-300">👤 com Vitor</p>
              </div>
              <p class="text-[15px] leading-snug text-[#E9EDEF]">Te vejo lá!</p>
              <p class="mt-1 text-right text-[11px] text-gray-400">10:31</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes shimmer {
    100% {
      transform: translateX(100%);
    }
  }
  .animate-shimmer {
    animation: shimmer 2s infinite;
  }
</style>
