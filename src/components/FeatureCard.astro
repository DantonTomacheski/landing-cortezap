---
interface Props {
  title: string;
  description: string;
  icon: string;
  testId?: string;
}

const { title, description, icon, testId } = Astro.props;
---

<div data-testid={testId} class="animate-on-scroll group flex flex-col rounded-xl border border-white/[0.06] bg-white/[0.02] p-6 transition-all duration-200 hover:bg-white/[0.04] hover:border-white/[0.1]">
  <div class="mb-4 text-text-secondary transition-colors group-hover:text-white">
    <Fragment set:html={icon} />
  </div>

  <h3 class="text-[15px] font-semibold text-white mb-2">{title}</h3>
  <p class="text-sm leading-relaxed text-text-secondary">{description}</p>
</div>
