---
interface Props {
  title: string;
  description: string;
  icon: string;
}

const { title, description, icon } = Astro.props;
---

<div class="animate-on-scroll group relative rounded-2xl border border-white/5 bg-white/[0.02] p-6 transition-all duration-300 hover:bg-white/[0.04] hover:-translate-y-1 hover:shadow-2xl hover:shadow-brand-500/10 overflow-hidden">
  <!-- Subtle top gradient border effect on hover -->
  <div class="absolute inset-x-0 top-0 h-px w-full bg-gradient-to-r from-transparent via-brand-500/0 to-transparent transition-all duration-500 group-hover:via-brand-500/50"></div>
  
  <!-- Subtle glow behind icon -->
  <div class="absolute top-6 left-6 h-12 w-12 rounded-full bg-brand-500/20 blur-xl opacity-0 transition-opacity duration-300 group-hover:opacity-100"></div>

  <div class="relative mb-6 flex h-12 w-12 items-center justify-center rounded-xl bg-white/5 border border-white/10 text-brand-400 transition-all duration-300 group-hover:text-brand-300 group-hover:border-brand-500/30 group-hover:bg-brand-500/10 shadow-[inset_0_1px_1px_rgba(255,255,255,0.1)]">
    <Fragment set:html={icon} />
  </div>
  
  <h3 class="relative text-xl font-bold tracking-tight text-white mb-3">{title}</h3>
  <p class="relative text-[15px] leading-relaxed text-text-secondary group-hover:text-gray-300 transition-colors duration-300">{description}</p>
</div>
