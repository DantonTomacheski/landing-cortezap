---
import { HOME_FAQ_ENTRIES } from '../data/seo';

const faqs = HOME_FAQ_ENTRIES;
---

<section id="faq" data-testid="faq-section" class="relative py-24 sm:py-32">
  <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="animate-on-scroll text-center flex flex-col items-center">
      <div class="mb-4 inline-flex items-center rounded-full border border-brand-500/20 bg-brand-500/10 px-3 py-1 text-sm font-medium text-brand-400">
        Dúvidas?
      </div>
      <h2 class="mt-2 text-4xl font-black tracking-tight sm:text-5xl text-white">Perguntas frequentes</h2>
      <p class="mt-6 text-lg text-text-secondary font-light">
        Tudo que você precisa saber sobre o CorteZap.
      </p>
    </div>

    <div class="mt-16 space-y-4">
      {faqs.map((faq, i) => (
        <details data-testid={`faq-item-${i}`} class="group rounded-2xl border border-white/10 bg-[#0A0A0A] transition-all hover:bg-white/[0.02]">
          <summary data-testid={`faq-item-${i}-summary`} class="flex cursor-pointer items-center justify-between px-6 py-5 text-[15px] font-bold text-white transition-colors hover:text-brand-400 [&::-webkit-details-marker]:hidden list-none select-none">
            {faq.question}
            <span class="ml-4 flex h-8 w-8 items-center justify-center rounded-full bg-white/5 transition-transform group-open:rotate-180 group-open:bg-brand-500/10 group-open:text-brand-400">
              <svg
                class="h-4 w-4 shrink-0 transition-transform"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M19 9l-7 7-7-7" />
              </svg>
            </span>
          </summary>
          <div data-testid={`faq-item-${i}-answer`} class="px-6 pb-6 pt-2 text-[15px] leading-relaxed text-text-secondary font-light">
            <div class="border-t border-white/10 pt-4">
               {faq.answer}
            </div>
          </div>
        </details>
      ))}
    </div>
  </div>
</section>
