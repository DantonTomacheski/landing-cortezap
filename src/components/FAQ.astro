---
import { HOME_FAQ_ENTRIES } from '../data/seo';

const faqs = HOME_FAQ_ENTRIES;
---

<section id="faq" data-testid="faq-section" class="relative py-24 sm:py-32">
  <div class="mx-auto max-w-2xl px-4 sm:px-6 lg:px-8">
    <div class="animate-on-scroll text-center">
      <h2 class="text-3xl font-semibold tracking-tight sm:text-4xl text-white">Perguntas frequentes</h2>
      <p class="mt-4 text-base text-text-secondary">
        Tudo que você precisa saber sobre o CorteZap.
      </p>
    </div>

    <div class="mt-12 divide-y divide-white/[0.06]">
      {faqs.map((faq, i) => (
        <details data-testid={`faq-item-${i}`} class="group">
          <summary data-testid={`faq-item-${i}-summary`} class="flex cursor-pointer items-center justify-between py-5 text-sm font-medium text-white transition-colors hover:text-text-secondary [&::-webkit-details-marker]:hidden list-none select-none">
            {faq.question}
            <svg
              class="h-4 w-4 shrink-0 text-text-muted transition-transform group-open:rotate-45"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 4v16m8-8H4" />
            </svg>
          </summary>
          <div data-testid={`faq-item-${i}-answer`} class="pb-5 text-sm leading-relaxed text-text-secondary">
            {faq.answer}
          </div>
        </details>
      ))}
    </div>
  </div>
</section>
