---
import PricingCard from './PricingCard.astro';
import { createWhatsAppLink, ABACATEPAY_LINK_BASICO, ABACATEPAY_LINK_PROFISSIONAL, ABACATEPAY_LINK_EMPRESARIAL } from '../data/seo';

const plans = [
  {
    name: 'Básico',
    price: 'R$ 79,90',
    priceNote: '/mês',
    cta: 'Assinar agora',
    ctaHref: ABACATEPAY_LINK_BASICO,
    ctaTarget: '_blank',
    features: [
      { text: 'Até 2 profissionais', included: true },
      { text: '1 usuário no painel', included: true },
      { text: '1 unidade', included: true },
      { text: 'Bot WhatsApp com IA (1 número)', included: true },
      { text: 'Agendamento automático', included: true },
      { text: 'Painel de gestão', included: true },
      { text: 'Relatórios financeiros básicos', included: true },
      { text: 'Base de clientes', included: true },
      { text: 'Notificações em tempo real', included: true },
      { text: 'Branding personalizado', included: false },
      { text: 'Suporte WhatsApp', included: true },
    ],
  },
  {
    name: 'Profissional',
    price: 'R$ 119,90',
    priceNote: '/mês',
    badge: 'Mais popular',
    highlighted: true,
    cta: 'Assinar agora',
    ctaHref: ABACATEPAY_LINK_PROFISSIONAL,
    ctaTarget: '_blank',
    features: [
      { text: 'Até 8 profissionais', included: true },
      { text: '3 usuários no painel', included: true },
      { text: '1 unidade', included: true },
      { text: 'Bot WhatsApp com IA (1 número)', included: true },
      { text: 'Agendamento automático', included: true },
      { text: 'Painel de gestão', included: true },
      { text: 'Relatórios financeiros completos', included: true },
      { text: 'Base de clientes', included: true },
      { text: 'Notificações em tempo real', included: true },
      { text: 'Branding personalizado (logo + cor)', included: true },
      { text: 'Suporte WhatsApp prioritário', included: true },
    ],
  },
  {
    name: 'Empresarial',
    price: 'R$ 199,90',
    priceNote: '/mês',
    cta: 'Assinar agora',
    ctaHref: ABACATEPAY_LINK_EMPRESARIAL,
    ctaTarget: '_blank',
    features: [
      { text: 'Profissionais ilimitados', included: true },
      { text: 'Usuários ilimitados no painel', included: true },
      { text: 'Unidades ilimitadas', included: true },
      { text: 'Bot WhatsApp com IA (múltiplos números)', included: true },
      { text: 'Agendamento automático', included: true },
      { text: 'Painel de gestão', included: true },
      { text: 'Relatórios completos + IA insights', included: true },
      { text: 'Base de clientes', included: true },
      { text: 'Notificações em tempo real', included: true },
      { text: 'Branding + domínio próprio', included: true },
      { text: 'Suporte dedicado', included: true },
    ],
  },
];
---

<section id="planos" class="relative py-24 sm:py-32">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="animate-on-scroll text-center flex flex-col items-center">
      <div class="mb-4 inline-flex items-center rounded-full border border-brand-500/20 bg-brand-500/10 px-3 py-1 text-sm font-medium text-brand-400">
        Investimento
      </div>
      <h2 class="mt-2 text-4xl font-black tracking-tight sm:text-5xl text-white">
        Planos flexíveis, focados<br class="hidden sm:block"/> <span class="text-brand-500">no seu crescimento</span>
      </h2>
      <p class="mt-6 max-w-2xl text-lg text-text-secondary font-light">
        Todos os planos incluem o bot WhatsApp com IA. Teste grátis por 7 dias. Não precisa de cartão.
      </p>
    </div>

    <!-- Billing toggle -->
    <div class="mt-12 flex items-center justify-center p-1.5 rounded-full bg-white/[0.03] border border-white/10 mx-auto w-max backdrop-blur-sm">
      <button
        data-billing="mensal"
        class="billing-toggle rounded-full px-6 py-2.5 text-[15px] font-bold transition-all bg-brand-500 text-white shadow-lg shadow-brand-500/25"
      >
        Mensal
      </button>
      <button
        data-billing="semestral"
        class="billing-toggle rounded-full px-6 py-2.5 text-[15px] font-semibold transition-all text-text-secondary hover:text-white"
      >
        Semestral <span class="ml-1 text-xs font-black text-brand-400">-10%</span>
      </button>
      <button
        data-billing="anual"
        class="billing-toggle rounded-full px-6 py-2.5 text-[15px] font-semibold transition-all text-text-secondary hover:text-white"
      >
        Anual <span class="ml-1 text-xs font-black text-brand-400">-20%</span>
      </button>
    </div>

    <div class="mt-16 grid gap-6 md:grid-cols-3 max-w-6xl mx-auto xl:gap-8 items-center relative">
        <!-- Background Ambient Glow behind center plan -->
        <div class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 w-[30%] h-[80%] bg-brand-500/30 blur-[120px] rounded-full pointer-events-none -z-10"></div>
    
      {plans.map((plan) => (
        <PricingCard
          name={plan.name}
          price={plan.price}
          priceNote={plan.priceNote}
          badge={plan.badge}
          features={plan.features}
          cta={plan.cta}
          ctaHref={plan.ctaHref}
          highlighted={plan.highlighted}
        />
      ))}
    </div>

    <!-- Custom plan -->
    <div class="animate-on-scroll mt-16 max-w-4xl mx-auto rounded-3xl border border-white/10 bg-[#0A0A0A]/50 p-8 sm:p-10 text-center backdrop-blur-md relative overflow-hidden group">
      <div class="absolute inset-0 bg-gradient-to-r from-brand-600/10 via-transparent to-brand-600/10 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
      
      <h3 class="relative z-10 text-2xl font-bold text-white">Precisa de algo personalizado?</h3>
      <p class="relative z-10 mt-3 text-base text-text-secondary font-light max-w-2xl mx-auto">
        Para redes com múltiplas unidades ou necessidades avançadas de integração, montamos uma proposta feita sob medida para a sua operação.
      </p>
      <a
        href={createWhatsAppLink('Olá! Quero saber mais sobre o plano personalizado do CorteZap')}
        target="_blank"
        rel="noopener noreferrer"
        class="relative z-10 mt-6 inline-flex items-center gap-2 rounded-xl border border-white/20 bg-white/5 px-8 py-3.5 text-[15px] font-bold text-white transition-all hover:border-brand-500/30 hover:bg-white/10 hover:text-brand-400"
      >
        Falar com consultor
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
      </a>
    </div>
  </div>
</section>

<script>
  const prices: Record<string, Record<string, string>> = {
    mensal: { 'Básico': 'R$ 79,90', 'Profissional': 'R$ 119,90', 'Empresarial': 'R$ 199,90' },
    semestral: { 'Básico': 'R$ 71,91', 'Profissional': 'R$ 107,91', 'Empresarial': 'R$ 179,91' },
    anual: { 'Básico': 'R$ 63,92', 'Profissional': 'R$ 95,92', 'Empresarial': 'R$ 159,92' },
  };

  const buttons = document.querySelectorAll('.billing-toggle');
  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const billing = (btn as HTMLElement).dataset.billing!;

      // Update active toggle
      buttons.forEach((b) => {
        b.classList.remove('bg-brand-500', 'text-white', 'shadow-lg', 'shadow-brand-500/25');
        b.classList.add('text-text-secondary');
        b.classList.remove('font-bold');
        b.classList.add('font-semibold');
      });
      btn.classList.add('bg-brand-500', 'text-white', 'shadow-lg', 'shadow-brand-500/25', 'font-bold');
      btn.classList.remove('text-text-secondary', 'font-semibold');

      // Update prices
      document.querySelectorAll('#planos h3').forEach((h3) => {
        const name = h3.textContent?.trim() || '';
        if (prices[billing]?.[name]) {
          const priceEl = h3.closest('[data-pricing-card]')?.querySelector('[data-price]') as HTMLElement | null;
          if (priceEl) priceEl.textContent = prices[billing][name];
        }
      });
    });
  });
</script>
