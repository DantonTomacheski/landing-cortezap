---
import PricingCard from './PricingCard.astro';
import { createWhatsAppLink, ABACATEPAY_LINK_ESSENCIAL, ABACATEPAY_LINK_PROFISSIONAL, ABACATEPAY_LINK_EMPRESARIAL } from '../data/seo';

const plans = [
  {
    name: 'Essencial',
    price: 'R$ 150',
    priceNote: '/mês',
    cta: 'Assinar agora',
    ctaHref: ABACATEPAY_LINK_ESSENCIAL,
    features: [
      { text: 'Até 2 profissionais', included: true },
      { text: '1 usuário no painel', included: true },
      { text: '1 unidade', included: true },
      { text: 'Bot WhatsApp com IA (1 número)', included: true },
      { text: 'Até 300 agendamentos/mês', included: true },
      { text: 'Agendamento automático 24h', included: true },
      { text: 'Painel de gestão', included: true },
      { text: 'Relatórios básicos', included: true },
      { text: 'Base de clientes', included: true },
      { text: 'Notificações em tempo real', included: true },
      { text: 'Branding personalizado', included: false },
      { text: 'Suporte WhatsApp', included: true },
    ],
  },
  {
    name: 'Profissional',
    price: 'R$ 200',
    priceNote: '/mês',
    badge: 'Popular',
    highlighted: true,
    cta: 'Assinar agora',
    ctaHref: ABACATEPAY_LINK_PROFISSIONAL,
    features: [
      { text: 'Até 8 profissionais', included: true },
      { text: '5 usuários no painel', included: true },
      { text: '1 unidade', included: true },
      { text: 'Bot WhatsApp com IA (1 número)', included: true },
      { text: 'Até 1.200 agendamentos/mês', included: true },
      { text: 'Agendamento automático 24h', included: true },
      { text: 'Painel de gestão', included: true },
      { text: 'Relatórios completos', included: true },
      { text: 'Base de clientes', included: true },
      { text: 'Notificações em tempo real', included: true },
      { text: 'Branding personalizado (logo + cor)', included: true },
      { text: 'Suporte prioritário', included: true },
    ],
  },
  {
    name: 'Empresarial',
    price: 'R$ 350',
    priceNote: '/mês',
    cta: 'Assinar agora',
    ctaHref: ABACATEPAY_LINK_EMPRESARIAL,
    features: [
      { text: 'Até 20 profissionais', included: true },
      { text: 'Usuários ilimitados no painel', included: true },
      { text: 'Até 3 unidades', included: true },
      { text: 'Bot WhatsApp com IA (até 3 números)', included: true },
      { text: 'Até 3.000 agendamentos/mês', included: true },
      { text: 'Agendamento automático 24h', included: true },
      { text: 'Painel de gestão', included: true },
      { text: 'Relatórios completos + IA insights', included: true },
      { text: 'Base de clientes', included: true },
      { text: 'Notificações em tempo real', included: true },
      { text: 'Branding + domínio próprio', included: true },
      { text: 'Suporte dedicado', included: true },
    ],
  },
];
---

<section id="planos" data-testid="pricing-section" class="relative py-24 sm:py-32">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="animate-on-scroll text-center">
      <h2 class="text-3xl font-semibold tracking-tight sm:text-4xl text-white">
        Planos
      </h2>
      <p class="mt-4 max-w-xl mx-auto text-base text-text-secondary">
        Todos incluem bot WhatsApp com IA via API Oficial da Meta. Sem risco de banimento.
      </p>
    </div>

    <div class="mt-16 grid gap-4 md:grid-cols-3 max-w-5xl mx-auto items-start">
      {plans.map((plan) => (
        <PricingCard
          name={plan.name}
          price={plan.price}
          priceNote={plan.priceNote}
          badge={plan.badge}
          features={plan.features}
          cta={plan.cta}
          ctaHref={plan.ctaHref}
          highlighted={plan.highlighted}
        />
      ))}
    </div>

    <!-- Custom plan -->
    <div data-testid="pricing-custom-plan" class="animate-on-scroll mt-12 max-w-3xl mx-auto rounded-xl border border-white/[0.06] bg-white/[0.02] p-6 sm:p-8 text-center">
      <h3 class="text-lg font-semibold text-white">Monte seu plano</h3>
      <p class="mt-2 text-sm text-text-secondary max-w-lg mx-auto">
        Configure exatamente o que sua barbearia precisa. Escolha barbeiros, unidades, números WhatsApp — com preço calculado em tempo real.
      </p>
      <div class="mt-3 text-sm text-text-muted">
        A partir de <span class="text-white font-medium">R$ 150</span>/mês
      </div>
      <a
        data-testid="pricing-custom-plan-cta"
        href={`${ABACATEPAY_LINK_ESSENCIAL.replace('plan=essencial', 'plan=custom')}`}
        class="mt-5 inline-flex items-center gap-1.5 text-sm text-text-secondary hover:text-white transition-colors"
      >
        Montar meu plano
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
      </a>
    </div>
  </div>
</section>
