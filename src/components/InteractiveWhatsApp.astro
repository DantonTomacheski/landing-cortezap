---
---
<interactive-whatsapp class="flex-1 w-full max-w-md lg:max-w-lg relative group perspective-1000 block">
  <!-- Glow behind mockup -->
  <div class="absolute -inset-1 rounded-[2.5rem] bg-gradient-to-tr from-brand-500/30 to-brand-600/30 blur-2xl transition duration-500 group-hover:from-brand-500/50 group-hover:to-brand-600/50 group-hover:blur-3xl"></div>
  
  <!-- Outer glass border -->
  <div class="relative rounded-[2.5rem] border border-white/10 bg-black/40 p-3 shadow-2xl backdrop-blur-2xl transition-transform duration-500 hover:rotate-y-[-5deg] hover:rotate-x-[5deg]">
    <!-- Inner phone screen -->
    <div class="overflow-hidden rounded-3xl border border-white/5 bg-[#0A0A0A] flex flex-col h-[560px]">
      <!-- Phone header -->
      <div class="flex items-center gap-3 bg-[#075E54] px-4 py-3 border-b border-white/10 z-10 shrink-0">
        <div class="flex h-10 w-10 items-center justify-center rounded-full bg-brand-500 text-sm font-bold text-white shadow-inner">CN</div>
        <div>
          <p class="text-sm font-semibold text-white tracking-wide">Barbearia Corte Nobre</p>
          <p class="text-xs text-green-200">online</p>
        </div>
        <div class="ml-auto flex gap-4 text-white/70">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"></path></svg>
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
        </div>
      </div>

      <!-- Chat area -->
      <div id="chat-container" class="flex-1 overflow-y-auto flex flex-col gap-3 bg-[#0B141A] px-4 py-5 scroll-smooth" style="background-image: url('data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%2220%22 height=%2220%22><rect width=%2220%22 height=%2220%22 fill=%22%23080c10%22/><circle cx=%2210%22 cy=%2210%22 r=%220.5%22 fill=%22%23ffffff05%22/></svg>');">
        <!-- Messages will be injected here -->
      </div>
      
      <!-- Input mock -->
      <div class="bg-[#202C33] px-3 py-2 flex items-center gap-2 shrink-0">
         <svg class="w-6 h-6 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
         <div class="flex-1 bg-[#2A3942] rounded-lg px-4 py-2">
            <span class="text-gray-400 text-[15px]">Mensagem</span>
         </div>
         <svg class="w-6 h-6 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z"></path></svg>
      </div>

    </div>
  </div>
</interactive-whatsapp>

<script>
  class InteractiveWhatsapp extends HTMLElement {
    constructor() {
      super();
      this.chatContainer = null;
      this.isTyping = false;
    }

    connectedCallback() {
      this.chatContainer = this.querySelector('#chat-container');
      this.initSequence();
    }

    formatTime() {
      return new Date().toLocaleTimeString('pt-BR', { hour: '2-digit', minute: '2-digit' });
    }

    scrollToBottom() {
      if (this.chatContainer) {
        setTimeout(() => {
          this.chatContainer.scrollTop = this.chatContainer.scrollHeight;
        }, 50);
      }
    }

    async initSequence() {
      await this.showTyping(800);
      this.addBotMessage(`Oi, João 👋<br><br>Bem-vindo à *Barbearia Corte Nobre* ✂️<br><br>Como posso te ajudar hoje?`);
      
      // Menu idêntico ao FLUXOS-BOT.txt
      this.addListMessage("Ver opções", [
        { id: "MENU_BOOKING", title: "Agendar horário", desc: "Marcar um corte" },
        { id: "MENU_MULTI", title: "Agendar mais de um", desc: "Pacote ou grupo" },
        { id: "MENU_PRICES", title: "Ver preços", desc: "Tabela de serviços" },
        { id: "MENU_MY_APPTS", title: "Meus agendamentos", desc: "Consultar/reagendar" }
      ]);
    }

    async handleAction(action) {
      if (this.isTyping) return;
      
      switch(action) {
        case "MENU_BOOKING":
          this.addUserMessage("Agendar horário");
          await this.showTyping(1200);
          
          // Fluxo V2: perguntando_self usando botões inline do WhatsApp (Meta Cloud API style)
          this.addInteractiveMessage("O corte é para você?", [
            { id: "SELF_YES", label: "Sim" },
            { id: "SELF_NO", label: "Não" }
          ]);
          break;
        case "SELF_YES":
          this.addUserMessage("Sim");
          await this.showTyping(800);
          this.addListMessage("Escolher serviço", [
            { id: "SRV_CORTE", title: "Corte Cabelo", desc: "30 min — R$ 35" },
            { id: "SRV_BARBA", title: "Barba", desc: "20 min — R$ 25" },
            { id: "SRV_COMBO", title: "Combo", desc: "50 min — R$ 55" }
          ], `Show 👌<br><br>Qual serviço vamos marcar para João?`);
          break;
        case "SRV_CORTE":
          this.addUserMessage("Corte Cabelo");
          await this.showTyping(1000);
          this.addListMessage("Escolher dia", [
            { id: "DIA_HOJE", title: "Hoje", desc: "Sábado, 02/03" },
            { id: "DIA_AMANHA", title: "Amanhã", desc: "Domingo, 03/03" }
          ], `*Corte Cabelo* (30 min) ✅<br><br>Qual dia funciona pra você?`);
          break;
        case "DIA_HOJE":
          this.addUserMessage("Hoje");
          await this.showTyping(1200);
          this.addListMessage("Ver opções", [
            { id: "HORA_09", title: "09:00", desc: "Disponível" },
            { id: "HORA_10", title: "10:30", desc: "Disponível" },
            { id: "HORA_14", title: "14:00", desc: "Disponível" }
          ], `📅 *Hoje — Sábado, 02/03*<br>Corte Cabelo (30 min)<br><br>Escolha um horário:`);
          break;
        case "HORA_09":
          this.addUserMessage("09:00");
          await this.showTyping(1500);
          this.addConfirmationMock();
          break;
        case "CONFIRMAR":
          this.addUserMessage("Confirmar");
          await this.showTyping(1500);
          this.addBotMessage(`Agendamento confirmado ✅<br><br>Corte Cabelo<br>📅 Sábado — 02/03 às 09:00<br>💈 Marcos<br>💰 R$ 35,00<br><br>Te espero lá! Qualquer coisa é só chamar 👊`);
          document.dispatchEvent(new CustomEvent('demo:booking-completed', {
            detail: {
              time: '09:00',
              name: 'João (Whatsapp)',
              service: 'Corte Cabelo',
              status: 'confirmado',
              price: 35
            }
          }));
          break;
      }
    }

    async showTyping(duration) {
      this.isTyping = true;
      const id = 'typing-' + Date.now();
      const html = `
        <div id="${id}" class="max-w-[85%] self-start rounded-2xl rounded-tl-none bg-[#1F2C34] px-4 py-3 shadow-sm border border-white/5 flex items-center gap-1 opacity-0 transition-opacity duration-300">
          <div class="w-2 h-2 bg-gray-400 rounded-full animate-bounce" style="animation-delay: 0ms"></div>
          <div class="w-2 h-2 bg-gray-400 rounded-full animate-bounce" style="animation-delay: 150ms"></div>
          <div class="w-2 h-2 bg-gray-400 rounded-full animate-bounce" style="animation-delay: 300ms"></div>
        </div>
      `;
      this.chatContainer.insertAdjacentHTML('beforeend', html);
      this.scrollToBottom();
      
      const el = this.querySelector('#' + id);
      setTimeout(() => el && el.classList.remove('opacity-0'), 50);

      return new Promise(resolve => {
        setTimeout(() => {
          if (el) el.remove();
          this.isTyping = false;
          resolve();
        }, duration);
      });
    }

    addBotMessage(text) {
      const html = `
        <div class="max-w-[85%] self-start rounded-2xl rounded-tl-none bg-[#1F2C34] px-4 py-2.5 shadow-sm border border-white/5 opacity-0 translate-y-2 transition-all duration-300">
          <p class="text-[15px] leading-snug text-[#E9EDEF] whitespace-pre-wrap">${text}</p>
          <p class="mt-1 text-right text-[11px] text-gray-400">${this.formatTime()}</p>
        </div>
      `;
      this.injectAndAnimate(html);
    }

    addUserMessage(text) {
      const html = `
        <div class="max-w-[75%] self-end rounded-2xl rounded-tr-none bg-[#005C4B] px-4 py-2.5 shadow-sm opacity-0 translate-y-2 transition-all duration-300">
          <p class="text-[15px] leading-snug text-[#E9EDEF]">${text}</p>
          <p class="mt-1 text-right text-[11px] text-green-300">${this.formatTime()} <span class="text-green-400 tracking-tighter ml-1">✓✓</span></p>
        </div>
      `;
      this.injectAndAnimate(html);
    }

    addListButton(buttonText, actionId) {
      const btnId = 'btn-' + Date.now();
      const html = `
        <div class="max-w-[85%] self-start w-full opacity-0 translate-y-2 transition-all duration-300">
          <button id="${btnId}" class="w-full flex items-center justify-center gap-2 rounded-xl bg-[#2A3942] hover:bg-[#32454f] transition-colors border border-white/10 px-4 py-3 text-[#00A884] font-medium text-sm shadow-sm">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
            ${buttonText}
          </button>
        </div>
      `;
      this.injectAndAnimate(html);
      
      setTimeout(() => {
        const btn = this.querySelector('#' + btnId);
        if (btn) {
          btn.addEventListener('click', () => {
            btn.parentElement.style.display = 'none'; // hide interactive elements after click
            this.handleAction(actionId);
          });
        }
      }, 100);
    }

    addInteractiveMessage(text, buttons) {
      const msgId = 'int-' + Date.now();
      
      let btnsHtml = '';
      buttons.forEach((btn, idx) => {
         btnsHtml += `<button data-action="${btn.id}" class="w-full relative px-4 py-3 hover:bg-white/5 transition-colors text-[15px] font-medium text-[#00A884] ${idx !== buttons.length - 1 ? 'border-b border-white/5' : ''}">${btn.label}</button>`;
      });

      const html = `
        <div id="${msgId}" class="max-w-[85%] self-start rounded-2xl rounded-tl-none bg-[#1F2C34] shadow-sm border border-white/5 opacity-0 translate-y-2 transition-all duration-300 overflow-hidden flex flex-col">
          <div class="px-4 py-2.5 pb-2">
            <p class="text-[15px] leading-snug text-[#E9EDEF] whitespace-pre-wrap">${text}</p>
            <p class="mt-1 text-right text-[11px] text-gray-400">${this.formatTime()}</p>
          </div>
          <div class="border-t border-white/5 flex flex-col">
            ${btnsHtml}
          </div>
        </div>
      `;
      this.injectAndAnimate(html);

      setTimeout(() => {
        const container = this.querySelector('#' + msgId);
        if (container) {
          const btns = container.querySelectorAll('button');
          btns.forEach(btn => {
            btn.addEventListener('click', () => {
              container.querySelectorAll('button').forEach(b => b.style.display = 'none');
              this.handleAction(btn.getAttribute('data-action'));
            });
          });
        }
      }, 100);
    }

    addListMessage(buttonText, options, prependedText = null) {
      const listId = 'list-' + Date.now();
      
      let optionsHtml = '';
      options.forEach((opt, idx) => {
        optionsHtml += `
          <button data-action="${opt.id}" class="w-full text-left px-4 py-3 hover:bg-white/5 transition-colors ${idx !== options.length - 1 ? 'border-b border-white/5' : ''}">
            <div class="text-[15px] text-[#E9EDEF] font-medium">${opt.title}</div>
            <div class="text-[13px] text-gray-400 mt-0.5">${opt.desc}</div>
          </button>
        `;
      });

      if (prependedText) {
         this.addBotMessage(prependedText);
      }

      const html = `
        <div id="${listId}" class="max-w-[85%] self-start w-full opacity-0 translate-y-2 transition-all duration-300 rounded-2xl bg-[#1F2C34] border border-white/5 shadow-sm overflow-hidden flex flex-col mt-1">
           <div class="bg-[#2A3942] px-4 py-2 border-b border-white/5 flex items-center gap-2">
             <svg class="w-4 h-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
             <span class="text-sm font-medium text-gray-300">${buttonText}</span>
           </div>
           <div class="flex flex-col">
             ${optionsHtml}
           </div>
        </div>
      `;
      
      this.injectAndAnimate(html);

      setTimeout(() => {
        const container = this.querySelector('#' + listId);
        if (container) {
          const btns = container.querySelectorAll('button');
          btns.forEach(btn => {
            btn.addEventListener('click', (e) => {
              container.style.display = 'none';
              this.handleAction(btn.getAttribute('data-action'));
            });
          });
        }
      }, 100);
    }

    addConfirmationMock() {
      const confId = 'conf-' + Date.now();
      const html = `
        <div id="${confId}" class="max-w-[85%] self-start rounded-2xl rounded-tl-none bg-[#1F2C34] shadow-sm border border-white/5 opacity-0 translate-y-2 transition-all duration-300 w-full overflow-hidden">
          <div class="px-4 py-3">
             <p class="text-[15px] font-bold text-[#E9EDEF] mb-2">Confirmação ✅</p>
             <p class="text-[14px] text-[#E9EDEF] leading-snug">Corte Cabelo<br>📅 Sábado — 02/03 às 09:00<br>💈 Marcos<br>💰 R$ 35,00<br><br>Está tudo certo?</p>
             <p class="mt-2 text-right text-[11px] text-gray-400">${this.formatTime()}</p>
          </div>
          <div class="flex border-t border-white/5">
             <button data-action="Alterar" class="flex-1 py-3 text-[#00A884] font-medium text-sm hover:bg-white/5 transition-colors border-r border-white/5">Alterar</button>
             <button data-action="CONFIRMAR" class="flex-1 py-3 text-[#00A884] font-medium text-sm hover:bg-white/5 transition-colors">Confirmar</button>
          </div>
        </div>
      `;
      this.injectAndAnimate(html);

      setTimeout(() => {
        const container = this.querySelector('#' + confId);
        if (container) {
          const btns = container.querySelectorAll('button');
          btns.forEach(btn => {
            btn.addEventListener('click', (e) => {
              const action = btn.getAttribute('data-action');
              if(action === 'CONFIRMAR') {
                container.style.display = 'none';
                this.handleAction('CONFIRMAR');
              }
            });
          });
        }
      }, 100);
    }

    injectAndAnimate(html) {
      this.chatContainer.insertAdjacentHTML('beforeend', html);
      const el = this.chatContainer.lastElementChild;
      
      // trigger reflow
      void el.offsetWidth;
      
      el.classList.remove('opacity-0', 'translate-y-2');
      this.scrollToBottom();
    }
  }

  customElements.define('interactive-whatsapp', InteractiveWhatsapp);
</script>
