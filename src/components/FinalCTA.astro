---
import { createWhatsAppLink } from '../data/seo';

const whatsappLink = createWhatsAppLink('Olá! Quero testar o CorteZap');
---

<section class="relative overflow-hidden py-24 sm:py-32 bg-[#050505]">
  <!-- Dynamic modern grid background -->
  <div class="absolute inset-0 bg-[linear-gradient(to_right,#ffffff08_1px,transparent_1px),linear-gradient(to_bottom,#ffffff08_1px,transparent_1px)] bg-[size:4rem_4rem] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_50%,#000_70%,transparent_100%)] opacity-30"></div>

  <!-- Background gradient -->
  <div class="pointer-events-none absolute inset-0">
    <div class="absolute top-1/2 left-1/2 h-[500px] w-[500px] -translate-x-1/2 -translate-y-1/2 rounded-full bg-brand-500/20 blur-[120px]"></div>
  </div>

  <div class="relative mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8 z-10">
    <div class="animate-on-scroll">
      <h2 class="text-4xl font-black tracking-tight sm:text-5xl lg:text-5xl text-white">
        A era do papelzinho acabou. <br/> <span class="bg-gradient-to-r from-brand-400 to-brand-600 bg-clip-text text-transparent pb-1 inline-block mt-2">Automatize sua barbearia com WhatsApp + painel.</span>
      </h2>
      <p class="mx-auto mt-6 max-w-xl text-[17px] text-text-secondary leading-relaxed font-light">
        Junte-se às barbearias que já usam bot para atendimento e painel para barbeiro em tempo real. Comece agora.
      </p>

      <div class="mt-10 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
        <a
          href={whatsappLink}
          target="_blank"
          rel="noopener noreferrer"
          class="relative overflow-hidden group inline-flex items-center gap-2 rounded-xl bg-brand-500 px-8 py-4 text-base font-bold text-white transition-all hover:bg-brand-400 hover:scale-105 shadow-[0_0_20px_rgba(249,115,22,0.4)] hover:shadow-[0_0_40px_rgba(249,115,22,0.6)]"
        >
          <div class="absolute inset-0 -translate-x-full bg-gradient-to-r from-transparent via-white/20 to-transparent group-hover:animate-shimmer"></div>
          
          <svg class="h-5 w-5 relative z-10" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          <span class="relative z-10">Comece grátis pelo WhatsApp</span>
        </a>
      </div>

      <p class="mt-6 text-[12px] font-bold text-text-muted/60 tracking-widest uppercase">
        7 dias grátis • Sem cartão • Cancele quando quiser
      </p>
    </div>
  </div>
</section>
