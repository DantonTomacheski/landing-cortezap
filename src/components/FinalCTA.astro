---
import { ABACATEPAY_LINK_DEFAULT } from '../data/seo';
---

<section data-testid="final-cta-section" class="relative py-24 sm:py-32 border-t border-white/[0.06]">
  <!-- Atmospheric gradient -->
  <div class="pointer-events-none absolute inset-0">
    <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-[60%] h-[60%] rounded-full bg-[radial-gradient(circle,rgba(120,80,200,0.04),transparent_70%)]"></div>
  </div>

  <div class="relative mx-auto max-w-2xl px-4 text-center sm:px-6 lg:px-8 z-10">
    <div class="animate-on-scroll">
      <h2 class="text-3xl font-semibold tracking-tight sm:text-4xl text-white">
        Pronto para automatizar sua barbearia?
      </h2>
      <p class="mx-auto mt-4 max-w-lg text-base text-text-secondary">
        Barbearias que usam o CorteZap reduzem no-shows e atendem clientes 24h sem esforço. Configure em 10 minutos.
      </p>

      <div class="mt-8 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
        <a
          data-testid="final-cta-btn"
          href={ABACATEPAY_LINK_DEFAULT}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-lg bg-brand-500 px-6 py-3 text-sm font-medium text-white transition-colors hover:bg-brand-600"
        >
          Começar agora
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
          </svg>
        </a>
      </div>

      <p class="mt-6 text-xs text-text-muted">
        Sem fidelidade · Cancele quando quiser · Suporte no WhatsApp
      </p>
    </div>
  </div>
</section>
