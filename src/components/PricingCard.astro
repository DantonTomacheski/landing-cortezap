---
interface Feature {
  text: string;
  included: boolean;
}

interface Props {
  name: string;
  price: string;
  priceNote?: string;
  badge?: string;
  features: Feature[];
  cta: string;
  ctaHref: string;
  highlighted?: boolean;
}

const { name, price, priceNote, badge, features, cta, ctaHref, highlighted = false } = Astro.props;
const testId = name.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '').replace(/\s+/g, '-');
---

<div
  data-pricing-card
  data-testid={`pricing-card-${testId}`}
  class:list={[
    'animate-on-scroll relative w-full flex flex-col rounded-xl border p-6 sm:p-8 transition-all duration-200',
    highlighted
      ? 'border-brand-500/30 bg-white/[0.03]'
      : 'border-white/[0.06] bg-white/[0.02] hover:bg-white/[0.03] hover:border-white/[0.1]',
  ]}
>
  {badge && (
    <span class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-full bg-brand-500 px-3 py-0.5 text-[11px] font-medium text-white">
      {badge}
    </span>
  )}

  <div class="relative z-10">
    <h3 class="text-sm font-medium text-text-secondary">{name}</h3>
    <div class="mt-3 flex items-baseline gap-1">
      <span class="text-3xl font-semibold tracking-tight text-white" data-price>{price}</span>
      {priceNote && <span class="text-sm text-text-muted">{priceNote}</span>}
    </div>
  </div>

  <ul class="mt-6 flex-1 space-y-3 relative z-10">
    {features.map((feature) => (
      <li class="flex items-start gap-2.5 text-sm">
        {feature.included ? (
          <svg class="mt-0.5 h-4 w-4 shrink-0 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
        ) : (
          <svg class="mt-0.5 h-4 w-4 shrink-0 text-white/10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 12H6" />
          </svg>
        )}
        <span class:list={[feature.included ? 'text-text-secondary' : 'text-text-muted']}>
          {feature.text}
        </span>
      </li>
    ))}
  </ul>

  <a
    data-testid={`pricing-card-${testId}-cta`}
    href={ctaHref}
    target="_blank"
    rel="noopener noreferrer"
    class:list={[
      'mt-8 block rounded-lg px-4 py-3 text-center text-sm font-medium transition-colors relative z-10',
      highlighted
        ? 'bg-brand-500 text-white hover:bg-brand-600'
        : 'bg-white/[0.06] text-white hover:bg-white/[0.1]',
    ]}
  >
    {cta}
  </a>
</div>
