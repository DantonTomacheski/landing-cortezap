---
interface Feature {
  text: string;
  included: boolean;
}

interface Props {
  name: string;
  price: string;
  priceNote?: string;
  badge?: string;
  features: Feature[];
  cta: string;
  ctaHref: string;
  highlighted?: boolean;
}

const { name, price, priceNote, badge, features, cta, ctaHref, highlighted = false } = Astro.props;
---

<div
  data-pricing-card
  class:list={[
    'animate-on-scroll relative w-full flex flex-col rounded-3xl border p-8 transition-all duration-300 hover:-translate-y-2 hover:shadow-[0_20px_40px_rgba(0,0,0,0.5)]',
    highlighted
      ? 'border-brand-500/50 bg-white/[0.03] shadow-2xl shadow-brand-500/20 backdrop-blur-md z-10'
      : 'border-white/10 bg-white/[0.02] hover:bg-white/[0.03] backdrop-blur-sm',
  ]}
>
  {highlighted && (
    <div class="absolute -inset-[1px] rounded-3xl bg-gradient-to-b from-brand-500/50 to-transparent pointer-events-none [mask-image:linear-gradient(to_bottom,white,transparent)]"></div>
  )}

  {badge && (
    <span class="absolute -top-3.5 left-1/2 -translate-x-1/2 rounded-full border border-brand-400 bg-brand-500 px-4 py-1 text-[11px] font-bold uppercase tracking-widest text-white shadow-lg shadow-brand-500/30">
      {badge}
    </span>
  )}

  <div class="text-center relative z-10">
    <h3 class:list={["text-xl font-bold", highlighted ? "text-brand-400" : "text-white"]}>{name}</h3>
    <div class="mt-4 flex flex-col items-center justify-center">
      <span class="text-5xl font-black tracking-tight text-white" data-price>{price}</span>
      {priceNote && <span class="mt-1 text-sm font-medium text-text-secondary">{priceNote}</span>}
    </div>
  </div>

  <ul class="mt-8 flex-1 space-y-4 relative z-10">
    {features.map((feature) => (
      <li class="flex items-start gap-3 text-[15px]">
        {feature.included ? (
          <svg class="mt-0.5 h-5 w-5 shrink-0 text-brand-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
          </svg>
        ) : (
          <svg class="mt-0.5 h-5 w-5 shrink-0 text-white/20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        )}
        <span class:list={[feature.included ? 'text-text-primary' : 'text-text-muted']}>
          {feature.text}
        </span>
      </li>
    ))}
  </ul>

  <a
    href={ctaHref}
    target="_blank"
    rel="noopener noreferrer"
    class:list={[
      'mt-10 block rounded-xl px-6 py-4 text-center text-[15px] font-bold transition-all relative z-10 overflow-hidden group',
      highlighted
        ? 'bg-brand-500 text-white shadow-[0_0_20px_rgba(249,115,22,0.3)] hover:bg-brand-400 hover:shadow-[0_0_30px_rgba(249,115,22,0.5)]'
        : 'border border-white/10 bg-white/5 text-white hover:bg-white/10 hover:border-white/20',
    ]}
  >
    <!-- Shimmer for highlighted -->
    {highlighted && (
        <div class="absolute inset-0 -translate-x-full bg-gradient-to-r from-transparent via-white/20 to-transparent group-hover:animate-shimmer"></div>
    )}
    <span class="relative z-10">{cta}</span>
  </a>
</div>
