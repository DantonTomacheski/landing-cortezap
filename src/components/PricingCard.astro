---
interface Feature {
  text: string;
  included: boolean;
}

interface Props {
  name: string;
  price: string;
  priceNote?: string;
  badge?: string;
  features: Feature[];
  cta: string;
  ctaHref: string;
  highlighted?: boolean;
}

const { name, price, priceNote, badge, features, cta, ctaHref, highlighted = false } = Astro.props;
---

<div
  class:list={[
    'animate-on-scroll relative flex flex-col rounded-2xl border p-6 sm:p-8',
    highlighted
      ? 'border-brand-500 bg-bg-card shadow-xl shadow-brand-500/10'
      : 'border-border bg-bg-card',
  ]}
>
  {badge && (
    <span class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-full bg-brand-500 px-4 py-1 text-xs font-semibold text-white">
      {badge}
    </span>
  )}

  <div class="text-center">
    <h3 class="text-lg font-semibold">{name}</h3>
    <div class="mt-4">
      <span class="text-4xl font-bold" data-price>{price}</span>
      {priceNote && <span class="text-sm text-text-secondary">{priceNote}</span>}
    </div>
  </div>

  <ul class="mt-8 flex-1 space-y-3">
    {features.map((feature) => (
      <li class="flex items-start gap-2.5 text-sm">
        {feature.included ? (
          <svg class="mt-0.5 h-4 w-4 shrink-0 text-brand-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
        ) : (
          <svg class="mt-0.5 h-4 w-4 shrink-0 text-text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        )}
        <span class:list={[feature.included ? 'text-text-secondary' : 'text-text-muted']}>
          {feature.text}
        </span>
      </li>
    ))}
  </ul>

  <a
    href={ctaHref}
    target="_blank"
    rel="noopener noreferrer"
    class:list={[
      'mt-8 block rounded-xl px-6 py-3 text-center text-sm font-semibold transition-all',
      highlighted
        ? 'bg-brand-500 text-white shadow-lg shadow-brand-500/25 hover:bg-brand-600'
        : 'border border-border text-text-primary hover:border-brand-500/30 hover:text-brand-400',
    ]}
  >
    {cta}
  </a>
</div>
