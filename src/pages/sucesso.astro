---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { createWhatsAppLink, PAINEL_URL } from '../data/seo';

const whatsappOnboarding = createWhatsAppLink('Olá! Acabei de assinar o CorteZap e preciso de ajuda para configurar');
---

<BaseLayout
  title="Assinatura confirmada | CorteZap"
  description="Sua assinatura do CorteZap foi confirmada. Veja os próximos passos para configurar sua barbearia."
  noindex={true}
>
  <Navbar />
  <main class="relative min-h-screen pt-28 pb-16 sm:pt-36 sm:pb-24 flex items-center">
    <!-- Background -->
    <div class="absolute inset-0 bg-[linear-gradient(to_right,#ffffff08_1px,transparent_1px),linear-gradient(to_bottom,#ffffff08_1px,transparent_1px)] bg-[size:4rem_4rem] [mask-image:radial-gradient(ellipse_80%_50%_at_50%_0%,#000_70%,transparent_100%)]"></div>
    <div class="absolute left-1/2 top-0 -translate-x-1/2 -translate-y-1/4 w-[600px] h-[300px] bg-green-500/15 blur-[120px] rounded-full pointer-events-none"></div>

    <div class="relative mx-auto max-w-2xl px-4 sm:px-6 lg:px-8 z-10 w-full">
      <!-- Success icon -->
      <div class="animate-on-scroll text-center">
        <div class="mx-auto flex h-20 w-20 items-center justify-center rounded-full bg-green-500/10 border border-green-500/20 mb-6">
          <svg class="h-10 w-10 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
          </svg>
        </div>

        <h1 class="text-3xl font-black tracking-tight sm:text-4xl text-white">
          Assinatura confirmada!
        </h1>
        <p class="mt-3 text-lg text-text-secondary font-light">
          Bem-vindo ao CorteZap. Sua barbearia está a poucos passos de funcionar no automático.
        </p>
      </div>

      <!-- Next steps -->
      <div class="animate-on-scroll mt-12 space-y-4">
        <h2 class="text-sm font-bold uppercase tracking-widest text-brand-400 text-center mb-6">Próximos passos</h2>

        <!-- Step 1 -->
        <div class="flex gap-4 rounded-2xl border border-white/10 bg-white/[0.02] p-5 backdrop-blur-sm">
          <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-brand-500/10 border border-brand-500/20 text-brand-400 font-bold text-lg">1</div>
          <div>
            <h3 class="font-bold text-white">Acesse o painel</h3>
            <p class="mt-1 text-sm text-text-secondary leading-relaxed">Entre no painel de gestão com o email usado na compra. Lá você configura tudo.</p>
            <a href={PAINEL_URL} target="_blank" rel="noopener noreferrer" class="mt-2 inline-flex items-center gap-1 text-sm font-medium text-brand-400 hover:text-brand-300 transition-colors">
              Abrir painel
              <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
            </a>
          </div>
        </div>

        <!-- Step 2 -->
        <div class="flex gap-4 rounded-2xl border border-white/10 bg-white/[0.02] p-5 backdrop-blur-sm">
          <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-brand-500/10 border border-brand-500/20 text-brand-400 font-bold text-lg">2</div>
          <div>
            <h3 class="font-bold text-white">Conecte seu WhatsApp</h3>
            <p class="mt-1 text-sm text-text-secondary leading-relaxed">No painel, escaneie o QR Code para parear o número da barbearia com o bot. Leva menos de 2 minutos.</p>
          </div>
        </div>

        <!-- Step 3 -->
        <div class="flex gap-4 rounded-2xl border border-white/10 bg-white/[0.02] p-5 backdrop-blur-sm">
          <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-brand-500/10 border border-brand-500/20 text-brand-400 font-bold text-lg">3</div>
          <div>
            <h3 class="font-bold text-white">Configure serviços e horários</h3>
            <p class="mt-1 text-sm text-text-secondary leading-relaxed">Cadastre seus serviços, defina a disponibilidade de cada profissional e pronto — o bot já começa a atender.</p>
          </div>
        </div>
      </div>

      <!-- CTA -->
      <div class="animate-on-scroll mt-10 text-center space-y-4">
        <a
          href={whatsappOnboarding}
          target="_blank"
          rel="noopener noreferrer"
          class="group relative inline-flex items-center justify-center gap-2 rounded-xl bg-green-600 px-8 py-4 text-base font-bold text-white transition-all hover:bg-green-500 hover:scale-[1.02] overflow-hidden w-full sm:w-auto"
        >
          <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Preciso de ajuda para configurar
        </a>

        <a
          href={PAINEL_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center gap-2 text-sm font-medium text-text-secondary hover:text-white transition-colors"
        >
          Ir direto para o painel
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
        </a>
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>
