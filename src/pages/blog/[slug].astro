---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import BlogCard from "../../components/BlogCard.astro";
import {
  createBreadcrumbSchema,
  createFaqSchema,
  toAbsoluteUrl,
  SITE_NAME,
  SITE_URL,
} from "../../data/seo";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const allPosts = await getCollection("blog");

const relatedPosts = allPosts
  .filter((p) => p.id !== post.id)
  .map((p) => {
    const sharedTags = p.data.tags.filter((tag) =>
      post.data.tags.includes(tag)
    ).length;
    const clusterBonus = p.data.cluster === post.data.cluster ? 3 : 0;
    return { post: p, score: sharedTags + clusterBonus };
  })
  .sort((a, b) => b.score - a.score)
  .slice(0, 3)
  .map((entry) => entry.post);

const breadcrumbs = [
  { name: "Início", path: "/" },
  { name: "Blog", path: "/blog" },
  { name: post.data.title, path: `/blog/${post.id}` },
];

const blogPostingSchema = {
  "@type": "BlogPosting",
  headline: post.data.title,
  description: post.data.description,
  inLanguage: "pt-BR",
  author: { "@type": "Organization", name: `Equipe ${SITE_NAME}` },
  publisher: { "@type": "Organization", name: SITE_NAME, url: SITE_URL },
  datePublished: post.data.publishedAt,
  dateModified: post.data.updatedAt,
  keywords: post.data.keywords.join(", "),
  mainEntityOfPage: toAbsoluteUrl(`/blog/${post.id}`),
};

const structuredData = [
  createBreadcrumbSchema(breadcrumbs),
  ...(post.data.faq.length > 0 ? [createFaqSchema(post.data.faq)] : []),
  blogPostingSchema,
];
---

<BaseLayout
  title={`${post.data.title} | Blog CorteZap`}
  description={post.data.description}
  canonicalPath={`/blog/${post.id}`}
  keywords={post.data.keywords}
  structuredData={structuredData}
>
  <Navbar />

  <main>
    <section class="relative overflow-hidden py-28 sm:py-36">
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(249,115,22,0.18),transparent_36%),radial-gradient(circle_at_bottom_right,rgba(251,191,36,0.08),transparent_28%)]"></div>
      <div class="relative mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
        <a
          href="/blog"
          class="inline-flex items-center gap-2 text-sm font-semibold text-text-secondary transition-colors hover:text-white"
        >
          <span aria-hidden="true">&larr;</span>
          Voltar para o blog
        </a>

        <div class="mt-8 flex flex-wrap items-center gap-3">
          <span class="rounded-full border border-brand-500/25 bg-brand-500/10 px-4 py-2 text-xs font-semibold uppercase tracking-[0.18em] text-brand-300">
            {post.data.clusterLabel}
          </span>
          <span class="rounded-full border border-white/10 bg-white/[0.04] px-4 py-2 text-xs font-semibold uppercase tracking-[0.18em] text-text-secondary">
            {post.data.funnelStage}
          </span>
        </div>

        <h1 class="mt-6 text-4xl font-black tracking-tight text-white sm:text-6xl">
          {post.data.title}
        </h1>

        <p class="mt-6 max-w-3xl text-lg leading-relaxed text-text-secondary">
          {post.data.description}
        </p>

        <div class="mt-8 flex flex-wrap items-center gap-4 text-sm text-text-muted">
          <span>Keyword: {post.data.primaryKeyword}</span>
          <span>&bull;</span>
          <time datetime={post.data.publishedAt}>
            {new Intl.DateTimeFormat("pt-BR", {
              day: "2-digit",
              month: "long",
              year: "numeric",
            }).format(new Date(post.data.publishedAt))}
          </time>
          <span>&bull;</span>
          <span>{post.data.readingTime} min de leitura</span>
        </div>
      </div>
    </section>

    <section class="relative pb-20">
      <div class="mx-auto grid max-w-7xl gap-8 px-4 sm:px-6 lg:grid-cols-[minmax(0,1fr)_320px] lg:px-8">
        <article class="rounded-[2rem] border border-white/10 bg-white/[0.02] p-6 sm:p-8 lg:p-10">
          <div class="prose-cortezap">
            <Content />
          </div>

          {post.data.faq.length > 0 && (
            <section class="mt-12">
              <h2 class="text-2xl font-black tracking-tight text-white sm:text-3xl">
                Perguntas frequentes
              </h2>
              <div class="mt-6 space-y-4">
                {post.data.faq.map((faq) => (
                  <details class="rounded-2xl border border-white/10 bg-white/[0.02] p-5">
                    <summary class="cursor-pointer text-base font-semibold text-white">
                      {faq.question}
                    </summary>
                    <p class="mt-3 text-sm leading-relaxed text-text-secondary">
                      {faq.answer}
                    </p>
                  </details>
                ))}
              </div>
            </section>
          )}

          <section class="mt-12 rounded-[2rem] border border-brand-500/20 bg-brand-500/8 p-6 sm:p-8">
            <h2 class="text-2xl font-black tracking-tight text-white">
              {post.data.ctaTitle}
            </h2>
            <p class="mt-4 max-w-3xl text-base leading-relaxed text-text-secondary">
              {post.data.ctaBody}
            </p>
            <a
              href="/#planos"
              class="mt-6 inline-flex rounded-xl bg-brand-500 px-6 py-3 text-sm font-bold text-white transition-colors hover:bg-brand-400"
            >
              Ver planos do CorteZap
            </a>
          </section>
        </article>

        <aside class="space-y-6 lg:sticky lg:top-24 lg:self-start">
          <div class="rounded-[2rem] border border-white/10 bg-white/[0.02] p-6">
            <h2 class="text-lg font-bold text-white">Sobre este post</h2>
            <div class="mt-4 space-y-4 text-sm text-text-secondary">
              <p>
                <span class="font-semibold text-white">Cluster:</span>{" "}
                {post.data.clusterLabel}
              </p>
              <p>
                <span class="font-semibold text-white">Keyword:</span>{" "}
                {post.data.primaryKeyword}
              </p>
              <p>
                <span class="font-semibold text-white">Tags:</span>{" "}
                {post.data.tags.slice(0, 4).join(", ")}
              </p>
              <p>
                <span class="font-semibold text-white">Atualizado:</span>{" "}
                <time datetime={post.data.updatedAt}>
                  {new Intl.DateTimeFormat("pt-BR", {
                    day: "2-digit",
                    month: "short",
                    year: "numeric",
                  }).format(new Date(post.data.updatedAt))}
                </time>
              </p>
            </div>
          </div>

          <div class="rounded-[2rem] border border-white/10 bg-white/[0.02] p-6">
            <h2 class="text-lg font-bold text-white">Leituras relacionadas</h2>
            <div class="mt-5 space-y-4">
              {relatedPosts.map((relatedPost) => (
                <BlogCard post={relatedPost} compact />
              ))}
            </div>
          </div>

          {post.data.internalLinks.length > 0 && (
            <div class="rounded-[2rem] border border-white/10 bg-white/[0.02] p-6">
              <h2 class="text-lg font-bold text-white">Veja também</h2>
              <ul class="mt-4 space-y-2">
                {post.data.internalLinks.map((link) => (
                  <li>
                    <a
                      href={link}
                      class="text-sm font-medium text-brand-300 transition-colors hover:text-white"
                    >
                      {link.replace("/blog/", "").replace(/-/g, " ")}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          )}
        </aside>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
