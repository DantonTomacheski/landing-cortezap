---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import BlogCard from "../../components/BlogCard.astro";
import { createBreadcrumbSchema, toAbsoluteUrl } from "../../data/seo";
import { BLOG_CLUSTERS } from "../../data/blogTaxonomy";

const allPosts = await getCollection("blog");
const posts = allPosts.sort(
  (a, b) =>
    new Date(b.data.publishedAt).getTime() -
    new Date(a.data.publishedAt).getTime()
);

function getPostsByCluster(clusterId: string) {
  return posts.filter((p) => p.data.cluster === clusterId);
}

const totalPosts = posts.length;
const totalClusters = BLOG_CLUSTERS.length;
const featuredPosts = posts.slice(0, 12);

const title = "Blog CorteZap | Sistema para barbearia, WhatsApp e gestão";
const description =
  "Blog do CorteZap com comparativos, guias de operação, WhatsApp para barbearia, SEO local e conteúdo para quem quer organizar agenda, equipe e financeiro.";

const breadcrumbs = [
  { name: "Início", path: "/" },
  { name: "Blog", path: "/blog" },
];

const structuredData = [
  createBreadcrumbSchema(breadcrumbs),
  {
    "@type": "CollectionPage",
    name: "Blog CorteZap",
    description: description,
    url: toAbsoluteUrl("/blog"),
  },
  {
    "@type": "ItemList",
    name: "Posts em destaque do blog CorteZap",
    itemListElement: featuredPosts.map((post, index) => ({
      "@type": "ListItem",
      position: index + 1,
      name: post.data.title,
      url: toAbsoluteUrl(`/blog/${post.id}`),
    })),
  },
];
---

<BaseLayout
  title={title}
  description={description}
  canonicalPath="/blog"
  keywords={[
    "blog sistema para barbearia",
    "blog agendamento whatsapp barbearia",
    "comparativos software barbearia",
    "seo local barbearia",
    "conteudo cortezap",
  ]}
  structuredData={structuredData}
>
  <Navbar />

  <main>
    <section class="relative overflow-hidden py-28 sm:py-36">
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(249,115,22,0.18),transparent_38%),radial-gradient(circle_at_bottom_right,rgba(251,191,36,0.08),transparent_30%)]"></div>
      <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <span class="inline-flex rounded-full border border-brand-500/25 bg-brand-500/10 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-brand-300">
          Blog CorteZap
        </span>
        <h1 class="mt-6 max-w-4xl text-4xl font-black tracking-tight text-white sm:text-6xl">
          Conteúdo para quem gerencia barbearia e quer parar de improvisar
        </h1>
        <p class="mt-6 max-w-3xl text-lg leading-relaxed text-text-secondary">
          Comparativos, money pages, guias de implementação, conteúdo local e posts de operação
          que nascem de intenção comercial real, não de volume cego.
        </p>

        <div class="mt-10 grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
          <div class="rounded-2xl border border-white/10 bg-white/[0.03] p-6">
            <p class="text-xs uppercase tracking-[0.18em] text-text-muted">Posts publicados</p>
            <p class="mt-3 text-4xl font-black text-white">{totalPosts}</p>
          </div>
          <div class="rounded-2xl border border-white/10 bg-white/[0.03] p-6">
            <p class="text-xs uppercase tracking-[0.18em] text-text-muted">Clusters de conteúdo</p>
            <p class="mt-3 text-4xl font-black text-white">{totalClusters}</p>
          </div>
          <div class="rounded-2xl border border-white/10 bg-white/[0.03] p-6">
            <p class="text-xs uppercase tracking-[0.18em] text-text-muted">Foco editorial</p>
            <p class="mt-3 text-xl font-bold text-white">Barbearia + WhatsApp + gestão</p>
          </div>
          <div class="rounded-2xl border border-white/10 bg-white/[0.03] p-6">
            <p class="text-xs uppercase tracking-[0.18em] text-text-muted">Modelo editorial</p>
            <p class="mt-3 text-xl font-bold text-white">Hubs + satélites + comparativos</p>
          </div>
        </div>
      </div>
    </section>

    <section class="relative py-20 border-y border-white/10">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
          <div>
            <h2 class="text-3xl font-black tracking-tight text-white sm:text-4xl">Hubs editoriais</h2>
            <p class="mt-3 max-w-3xl text-base leading-relaxed text-text-secondary">
              Cada hub concentra uma intenção de busca maior e organiza a malha interna do cluster.
            </p>
          </div>
          <p class="text-sm text-text-muted">Estrutura editorial pensada para reduzir canibalização.</p>
        </div>

        <div class="mt-8 grid gap-6 lg:grid-cols-2 xl:grid-cols-3">
          {BLOG_CLUSTERS.map((cluster) => {
            const clusterPosts = getPostsByCluster(cluster.id);
            return (
              <a
                href={cluster.hubPath}
                class="group rounded-2xl border border-white/10 bg-white/[0.02] p-6 transition-colors hover:border-brand-500/35 hover:bg-white/[0.04]"
              >
                <div class="flex items-center justify-between gap-4">
                  <span class="rounded-full bg-white/[0.04] px-3 py-1 text-xs font-semibold text-brand-300">
                    {cluster.shortLabel}
                  </span>
                  <span class="text-xs text-text-muted">{clusterPosts.length} posts</span>
                </div>
                <h3 class="mt-4 text-2xl font-bold tracking-tight text-white transition-colors group-hover:text-brand-300">
                  {cluster.hubTitle}
                </h3>
                <p class="mt-3 text-sm leading-relaxed text-text-secondary">{cluster.hubDescription}</p>
                <p class="mt-4 text-xs uppercase tracking-[0.18em] text-text-muted">
                  Prioridade editorial: {cluster.publishPriority}
                </p>
              </a>
            );
          })}
        </div>
      </div>
    </section>

    <section class="relative py-20 border-y border-white/10">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <h2 class="text-3xl font-black tracking-tight text-white sm:text-4xl">Posts em destaque</h2>
        <p class="mt-3 max-w-3xl text-base leading-relaxed text-text-secondary">
          Os artigos mais recentes do blog cobrindo comparativos, operação, WhatsApp e decisão de compra.
        </p>

        <div class="mt-8 grid gap-6 lg:grid-cols-3">
          {featuredPosts.slice(0, 6).map((post) => (
            <BlogCard post={post} />
          ))}
        </div>
      </div>
    </section>

    <section class="relative py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <h2 class="text-3xl font-black tracking-tight text-white sm:text-4xl">Clusters de conteúdo</h2>
        <div class="mt-8 grid gap-6 lg:grid-cols-2">
          {BLOG_CLUSTERS.map((cluster) => {
            const clusterPosts = getPostsByCluster(cluster.id);
            if (clusterPosts.length === 0) return null;
            return (
              <article class="rounded-2xl border border-white/10 bg-white/[0.02] p-6">
                <div class="flex items-center justify-between gap-4">
                  <h3 class="text-2xl font-bold text-white">{cluster.label}</h3>
                  <span class="rounded-full bg-white/[0.04] px-3 py-1 text-xs font-semibold text-brand-300">
                    {clusterPosts.length} posts
                  </span>
                </div>
                <p class="mt-3 text-sm leading-relaxed text-text-secondary">{cluster.hubDescription}</p>
                <a
                  href={cluster.hubPath}
                  class="mt-4 inline-flex text-sm font-semibold text-brand-300 transition-colors hover:text-white"
                >
                  Abrir hub
                </a>
                <div class="mt-6 grid gap-4 md:grid-cols-2">
                  {clusterPosts.slice(0, 4).map((post) => (
                    <BlogCard post={post} compact />
                  ))}
                </div>
              </article>
            );
          })}
        </div>
      </div>
    </section>

    <section id="arquivo" class="relative py-20 border-t border-white/10">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <h2 class="text-3xl font-black tracking-tight text-white sm:text-4xl">Arquivo completo</h2>
        <p class="mt-3 max-w-3xl text-base leading-relaxed text-text-secondary">
          Todos os artigos publicados no blog, ordenados por data.
        </p>

        <div class="mt-10 grid gap-6 lg:grid-cols-2">
          {posts.map((post) => (
            <a
              href={`/blog/${post.id}`}
              class="group flex items-start justify-between gap-4 rounded-2xl border border-white/10 bg-white/[0.02] px-5 py-4 transition-colors hover:border-brand-500/35 hover:bg-white/[0.04]"
            >
              <div>
                <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-brand-300">
                  {post.data.clusterLabel}
                </p>
                <h3 class="mt-2 text-lg font-bold text-white transition-colors group-hover:text-brand-300">
                  {post.data.title}
                </h3>
                <p class="mt-2 text-sm leading-relaxed text-text-secondary">{post.data.description}</p>
              </div>
              <span class="shrink-0 text-sm text-text-muted">{post.data.readingTime} min</span>
            </a>
          ))}
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
