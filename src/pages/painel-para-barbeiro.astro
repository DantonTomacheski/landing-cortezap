---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import {
  CORE_KEYWORDS,
  createBreadcrumbSchema,
  createFaqSchema,
  createWhatsAppLink,
} from "../data/seo";

const whatsappLink = createWhatsAppLink("Olá! Quero conhecer o painel para barbeiro do CorteZap");

const modules = [
  {
    title: "Agenda operacional",
    description:
      "Visualização diária, confirmação, reagendamento e cancelamento com filtros por status e profissional.",
  },
  {
    title: "Clientes e histórico",
    description:
      "Cadastro com histórico de agendamentos, frequência e contato WhatsApp para relacionamento ativo.",
  },
  {
    title: "Financeiro da barbearia",
    description:
      "Faturamento por período, ticket médio, top serviços, top clientes e relatórios para decisão.",
  },
  {
    title: "Equipe e serviços",
    description:
      "Defina serviços por barbeiro, horários por profissional e acompanhe produtividade individual.",
  },
  {
    title: "Notificações em tempo real",
    description:
      "Novos agendamentos e mudanças de status no painel com alertas instantâneos para a operação.",
  },
  {
    title: "Perfis de acesso",
    description:
      "Controle de permissões por função com acesso específico para administrador e barbeiro.",
  },
];

const faqEntries = [
  {
    question: "O painel funciona para barbeiro e para dono da barbearia?",
    answer:
      "Sim. Você pode operar com perfis separados para barbeiro e admin, cada um com seu nível de acesso.",
  },
  {
    question: "Consigo controlar pausas e horários por profissional?",
    answer:
      "Sim. O sistema permite ajuste de horários e pausas para manter disponibilidade real na agenda.",
  },
  {
    question: "Dá para acompanhar financeiro sem planilha?",
    answer:
      "Sim. O painel consolida receita, ticket médio, serviços e clientes mais relevantes no período selecionado.",
  },
  {
    question: "O painel recebe os agendamentos do WhatsApp automaticamente?",
    answer:
      "Sim. Tudo que acontece no WhatsApp entra no painel em tempo real, sem digitação manual.",
  },
];

const breadcrumbs = [
  { name: "Início", path: "/" },
  { name: "Painel para Barbeiro", path: "/painel-para-barbeiro" },
];

const structuredData = [
  createBreadcrumbSchema(breadcrumbs),
  createFaqSchema(faqEntries),
  {
    "@type": "CollectionPage",
    "name": "Painel para barbeiro",
    "description": "Módulos de gestão para agenda, clientes, financeiro e equipe da barbearia.",
  },
];

const keywords = [
  ...CORE_KEYWORDS,
  "painel de barbeiro",
  "painel de gestao barbearia",
  "dashboard para barbearia",
];
---

<BaseLayout
  title="Painel para Barbeiro e Dono de Barbearia | CorteZap"
  description="Conheça o painel para barbeiro do CorteZap: agenda em tempo real, clientes, financeiro, serviços, equipe e permissões por perfil."
  keywords={keywords}
  canonicalPath="/painel-para-barbeiro"
  structuredData={structuredData}
>
  <Navbar />
  <main>
    <section class="relative py-28 sm:py-36">
      <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
        <p class="text-sm font-semibold uppercase tracking-widest text-brand-400">Página estratégica</p>
        <h1 class="mt-4 text-4xl font-black tracking-tight text-white sm:text-6xl">
          Painel para barbeiro com visão completa da operação
        </h1>
        <p class="mt-6 text-lg leading-relaxed text-text-secondary">
          Do primeiro agendamento ao fechamento do dia, o painel da barbearia concentra agenda, clientes,
          financeiro, equipe e notificações em tempo real para você operar com previsibilidade.
        </p>
        <div class="mt-10 flex flex-wrap gap-4">
          <a
            href={whatsappLink}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center rounded-xl bg-brand-500 px-6 py-3 text-sm font-bold text-white transition-colors hover:bg-brand-400"
          >
            Testar painel no WhatsApp
          </a>
          <a href="/sistema-para-barbearia" class="inline-flex items-center rounded-xl border border-white/15 px-6 py-3 text-sm font-semibold text-white hover:border-brand-500/40 hover:text-brand-300">
            Ver sistema completo
          </a>
        </div>
      </div>
    </section>

    <section class="relative pb-16">
      <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
        <h2 class="text-3xl font-black tracking-tight text-white sm:text-4xl">
          Módulos do painel para barbeiro
        </h2>
        <div class="mt-10 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
          {modules.map((module) => (
            <article class="rounded-2xl border border-white/10 bg-white/[0.02] p-6">
              <h3 class="text-xl font-bold text-white">{module.title}</h3>
              <p class="mt-3 text-sm leading-relaxed text-text-secondary">{module.description}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="relative py-20">
      <div class="mx-auto grid max-w-6xl gap-6 px-4 sm:px-6 lg:grid-cols-2 lg:px-8">
        <article class="rounded-2xl border border-white/10 bg-white/[0.02] p-6">
          <h2 class="text-2xl font-black text-white">Para o barbeiro no dia a dia</h2>
          <ul class="mt-4 space-y-3 text-sm text-text-secondary">
            <li>Visualização de agenda sem conflito de horários.</li>
            <li>Confirmação rápida de atendimento e conclusão de serviços.</li>
            <li>Acesso às informações essenciais sem ruído operacional.</li>
          </ul>
        </article>
        <article class="rounded-2xl border border-white/10 bg-white/[0.02] p-6">
          <h2 class="text-2xl font-black text-white">Para o administrador da barbearia</h2>
          <ul class="mt-4 space-y-3 text-sm text-text-secondary">
            <li>Controle de equipe, catálogo de serviços e horários por unidade.</li>
            <li>Análise de receita, ticket médio e demanda por período.</li>
            <li>Decisões com base em dados reais, não em suposição.</li>
          </ul>
        </article>
      </div>
    </section>

    <section class="relative py-20">
      <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
        <h2 class="text-3xl font-black tracking-tight text-white sm:text-4xl">FAQ do painel para barbeiro</h2>
        <div class="mt-8 space-y-4">
          {faqEntries.map((faq) => (
            <details class="rounded-xl border border-white/10 bg-white/[0.02] p-5">
              <summary class="cursor-pointer text-base font-semibold text-white">{faq.question}</summary>
              <p class="mt-3 text-sm leading-relaxed text-text-secondary">{faq.answer}</p>
            </details>
          ))}
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
