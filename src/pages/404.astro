---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { createWhatsAppLink } from '../data/seo';

const whatsappLink = createWhatsAppLink('Olá! Quero testar o CorteZap');

const links = [
  { label: 'Agendamento WhatsApp', href: '/agendamento-whatsapp-barbearia' },
  { label: 'Painel para Barbeiro', href: '/painel-para-barbeiro' },
  { label: 'Sistema para Barbearia', href: '/sistema-para-barbearia' },
  { label: 'Planos', href: '/#planos' },
  { label: 'FAQ', href: '/#faq' },
];
---

<BaseLayout
  title="Página não encontrada | CorteZap"
  description="Esta página não existe. Acesse o CorteZap e descubra como automatizar o agendamento da sua barbearia pelo WhatsApp."
  canonicalPath="/404"
  noindex={true}
>
  <Navbar />
  <main class="relative min-h-screen flex items-center justify-center py-24 px-4">
    <!-- Ambient glow -->
    <div class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[300px] bg-brand-500/10 blur-[120px] rounded-full pointer-events-none"></div>

    <div class="relative z-10 text-center max-w-xl mx-auto">
      <p class="text-8xl font-black text-brand-500/30">404</p>
      <h1 class="mt-4 text-3xl font-black tracking-tight text-white sm:text-4xl">
        Página não encontrada
      </h1>
      <p class="mt-4 text-lg text-text-secondary font-light">
        A página que você buscou não existe ou foi movida. Veja os links abaixo para encontrar o que precisa.
      </p>

      <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="/"
          class="inline-flex items-center gap-2 rounded-xl bg-brand-500 px-6 py-3 text-sm font-bold text-white transition-colors hover:bg-brand-400"
        >
          Ir para a página inicial
        </a>
        <a
          href={whatsappLink}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-xl border border-white/15 px-6 py-3 text-sm font-semibold text-white hover:border-brand-500/40 hover:text-brand-300"
        >
          Falar no WhatsApp
        </a>
      </div>

      <nav class="mt-14 border-t border-white/10 pt-10">
        <p class="text-xs font-semibold uppercase tracking-widest text-text-secondary mb-6">Páginas principais</p>
        <ul class="flex flex-wrap justify-center gap-4">
          {links.map((link) => (
            <li>
              <a
                href={link.href}
                class="rounded-lg border border-white/10 bg-white/[0.02] px-4 py-2 text-sm text-text-secondary transition-colors hover:border-brand-500/30 hover:text-white"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </div>
  </main>
  <Footer />
</BaseLayout>
