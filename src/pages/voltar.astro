---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { createWhatsAppLink, ABACATEPAY_LINK_DEFAULT } from '../data/seo';

const whatsappDuvidas = createWhatsAppLink('Olá! Tenho dúvidas sobre o CorteZap antes de assinar');
---

<BaseLayout
  title="Voltar para o checkout | CorteZap"
  description="Continue sua assinatura do CorteZap."
  noindex={true}
>
  <Navbar />
  <main class="relative min-h-screen pt-28 pb-16 sm:pt-36 sm:pb-24">
    <!-- Background -->
    <div class="absolute inset-0 bg-[linear-gradient(to_right,#ffffff08_1px,transparent_1px),linear-gradient(to_bottom,#ffffff08_1px,transparent_1px)] bg-[size:4rem_4rem] [mask-image:radial-gradient(ellipse_80%_50%_at_50%_0%,#000_70%,transparent_100%)]"></div>
    <div class="absolute left-1/2 top-0 -translate-x-1/2 -translate-y-1/4 w-[600px] h-[300px] bg-brand-500/15 blur-[120px] rounded-full pointer-events-none"></div>

    <div class="relative mx-auto max-w-2xl px-4 sm:px-6 lg:px-8 z-10 w-full">
      <!-- Headline empática -->
      <div class="animate-on-scroll text-center">
        <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-brand-500/10 border border-brand-500/20 mb-6">
          <svg class="h-8 w-8 text-brand-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>

        <h1 class="text-3xl font-black tracking-tight sm:text-4xl text-white">
          Sem pressa — a gente te espera.
        </h1>
        <p class="mt-3 text-lg text-text-secondary font-light max-w-lg mx-auto">
          Se ficou alguma dúvida, veja o que nossos clientes mais perguntam antes de assinar.
        </p>
      </div>

      <!-- Objeções resolvidas -->
      <div class="animate-on-scroll mt-12 grid grid-cols-2 gap-3 sm:gap-4">
        <div class="flex items-start gap-3 rounded-2xl border border-white/10 bg-white/[0.02] p-4 backdrop-blur-sm">
          <svg class="h-5 w-5 shrink-0 text-green-400 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
          </svg>
          <div>
            <p class="text-sm font-bold text-white">7 dias grátis</p>
            <p class="text-xs text-text-secondary mt-0.5">Teste sem compromisso</p>
          </div>
        </div>

        <div class="flex items-start gap-3 rounded-2xl border border-white/10 bg-white/[0.02] p-4 backdrop-blur-sm">
          <svg class="h-5 w-5 shrink-0 text-green-400 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
          </svg>
          <div>
            <p class="text-sm font-bold text-white">Cancele quando quiser</p>
            <p class="text-xs text-text-secondary mt-0.5">Sem multa ou burocracia</p>
          </div>
        </div>

        <div class="flex items-start gap-3 rounded-2xl border border-white/10 bg-white/[0.02] p-4 backdrop-blur-sm">
          <svg class="h-5 w-5 shrink-0 text-green-400 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
          </svg>
          <div>
            <p class="text-sm font-bold text-white">Suporte humano</p>
            <p class="text-xs text-text-secondary mt-0.5">Atendimento no WhatsApp</p>
          </div>
        </div>

        <div class="flex items-start gap-3 rounded-2xl border border-white/10 bg-white/[0.02] p-4 backdrop-blur-sm">
          <svg class="h-5 w-5 shrink-0 text-green-400 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
          </svg>
          <div>
            <p class="text-sm font-bold text-white">Setup em 10 min</p>
            <p class="text-xs text-text-secondary mt-0.5">Configuração rápida</p>
          </div>
        </div>
      </div>

      <!-- Prova social compacta -->
      <div class="animate-on-scroll mt-10 rounded-2xl border border-white/10 bg-white/[0.02] p-6 backdrop-blur-sm text-center">
        <div class="flex items-center justify-center gap-6 sm:gap-10">
          <div>
            <p class="text-2xl font-black text-white">5.000+</p>
            <p class="text-xs text-text-secondary font-medium mt-0.5">agendamentos</p>
          </div>
          <div class="h-8 w-px bg-white/10"></div>
          <div>
            <p class="text-2xl font-black text-white">1.200+</p>
            <p class="text-xs text-text-secondary font-medium mt-0.5">clientes atendidos</p>
          </div>
          <div class="h-8 w-px bg-white/10"></div>
          <div>
            <p class="text-2xl font-black text-white">99.8%</p>
            <p class="text-xs text-text-secondary font-medium mt-0.5">uptime</p>
          </div>
        </div>
      </div>

      <!-- FAQ rápido -->
      <div class="animate-on-scroll mt-10 space-y-3">
        <h2 class="text-sm font-bold uppercase tracking-widest text-brand-400 text-center mb-4">Dúvidas frequentes</h2>

        <details class="group rounded-2xl border border-white/10 bg-white/[0.02] backdrop-blur-sm">
          <summary class="flex cursor-pointer items-center justify-between p-5 text-[15px] font-semibold text-white">
            Preciso de cartão de crédito para testar?
            <svg class="h-5 w-5 text-text-secondary transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
          </summary>
          <p class="px-5 pb-5 text-sm text-text-secondary leading-relaxed -mt-1">Depende do plano escolhido. O pagamento é processado pelo AbacatePay com total segurança, e você pode cancelar a qualquer momento sem burocracia.</p>
        </details>

        <details class="group rounded-2xl border border-white/10 bg-white/[0.02] backdrop-blur-sm">
          <summary class="flex cursor-pointer items-center justify-between p-5 text-[15px] font-semibold text-white">
            E se eu não gostar?
            <svg class="h-5 w-5 text-text-secondary transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
          </summary>
          <p class="px-5 pb-5 text-sm text-text-secondary leading-relaxed -mt-1">Você cancela direto no painel ou pelo WhatsApp de suporte. Sem multa, sem complicação. É simples assim.</p>
        </details>

        <details class="group rounded-2xl border border-white/10 bg-white/[0.02] backdrop-blur-sm">
          <summary class="flex cursor-pointer items-center justify-between p-5 text-[15px] font-semibold text-white">
            O sistema é difícil de configurar?
            <svg class="h-5 w-5 text-text-secondary transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
          </summary>
          <p class="px-5 pb-5 text-sm text-text-secondary leading-relaxed -mt-1">Não. Você pareia o WhatsApp por QR Code, cadastra seus serviços e pronto. Em 10 minutos o bot já está atendendo. E nosso suporte ajuda no que precisar.</p>
        </details>
      </div>

      <!-- CTAs -->
      <div class="animate-on-scroll mt-10 text-center space-y-4">
        <a
          href={ABACATEPAY_LINK_DEFAULT}
          target="_blank"
          rel="noopener noreferrer"
          class="group relative inline-flex items-center justify-center gap-2 rounded-xl bg-brand-500 px-8 py-4 text-base font-bold text-white transition-all hover:bg-brand-400 hover:scale-[1.02] overflow-hidden w-full sm:w-auto shadow-[0_0_20px_rgba(249,115,22,0.3)] hover:shadow-[0_0_30px_rgba(249,115,22,0.5)]"
        >
          <div class="absolute inset-0 -translate-x-full bg-gradient-to-r from-transparent via-white/20 to-transparent group-hover:animate-shimmer"></div>
          <svg class="h-5 w-5 relative z-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
          </svg>
          <span class="relative z-10">Voltar ao checkout</span>
        </a>

        <div>
          <a
            href={whatsappDuvidas}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-2 text-sm font-medium text-text-secondary hover:text-white transition-colors"
          >
            <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Prefere tirar dúvidas antes?
          </a>
        </div>
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>

<style>
  @keyframes shimmer {
    100% {
      transform: translateX(100%);
    }
  }
  .animate-shimmer {
    animation: shimmer 2s infinite;
  }
</style>
